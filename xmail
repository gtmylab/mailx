# Complete fixed configure_opendkim function
configure_opendkim() {
    local DOMAIN=$1
    local SELECTOR=$2
    local OPENDKIM_CONF="/etc/opendkim.conf"
    local OPENDKIM_DIR="/etc/opendkim"
    local SOCKET_DIR="/var/spool/postfix/opendkim"
    
    log_info "Configuring OpenDKIM for domain $DOMAIN..."
    
    # Stop OpenDKIM if running
    systemctl stop opendkim 2>/dev/null || true
    pkill -f opendkim 2>/dev/null || true
    
    # Create socket directory with correct permissions
    mkdir -p "$SOCKET_DIR"
    chown opendkim:postfix "$SOCKET_DIR"
    chmod 750 "$SOCKET_DIR"
    
    # Create necessary directories
    mkdir -p "$OPENDKIM_DIR/keys/$DOMAIN"
    
    # Fix permissions
    chown -R opendkim:opendkim "$OPENDKIM_DIR" 2>/dev/null || true
    chmod 750 "$OPENDKIM_DIR"
    chmod 750 "$OPENDKIM_DIR/keys"
    chmod 750 "$OPENDKIM_DIR/keys/$DOMAIN"
    
    # Create main configuration
    cat > "$OPENDKIM_CONF" <<EOF
# OpenDKIM configuration
AutoRestart             yes
AutoRestartRate         10/1M
Background              yes
Canonicalization        relaxed/simple
DNSTimeout              5
Mode                    sv
OversignHeaders         From
SenderHeaders           From
SignatureAlgorithm      rsa-sha256
Socket                  local:$SOCKET_DIR/opendkim.sock
Syslog                  yes
SyslogSuccess           yes
TemporaryDirectory      /var/tmp
UMask                   002
UserID                  opendkim:opendkim

# Domain configuration
Domain                  $DOMAIN
Selector                $SELECTOR
KeyFile                 $OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private
EOF
    
    # Create KeyTable
    cat > "$OPENDKIM_DIR/KeyTable" <<EOF
$SELECTOR._domainkey.$DOMAIN $DOMAIN:$SELECTOR:$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private
EOF
    
    # Create SigningTable
    cat > "$OPENDKIM_DIR/SigningTable" <<EOF
*@$DOMAIN $SELECTOR._domainkey.$DOMAIN
EOF
    
    # Create TrustedHosts
    cat > "$OPENDKIM_DIR/TrustedHosts" <<EOF
127.0.0.1
::1
localhost
$DOMAIN
mail.$DOMAIN
EOF
    
    # Set proper permissions
    chmod 644 "$OPENDKIM_CONF"
    chmod 644 "$OPENDKIM_DIR/KeyTable"
    chmod 644 "$OPENDKIM_DIR/SigningTable"
    chmod 644 "$OPENDKIM_DIR/TrustedHosts"
    
    # Ensure key files have correct permissions
    if [ -f "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private" ]; then
        chmod 600 "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private"
        chown opendkim:opendkim "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private"
    fi
    
    if [ -f "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.txt" ]; then
        chmod 644 "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.txt"
        chown opendkim:opendkim "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.txt"
    fi
    
    # Remove any problematic systemd overrides
    rm -f /etc/systemd/system/opendkim.service.d/override.conf 2>/dev/null || true
    systemctl daemon-reload
    
    # Test configuration before starting
    log_info "Testing OpenDKIM configuration..."
    if opendkim -f -x "$OPENDKIM_CONF" -c 2>&1 | grep -q "configuration OK\|no errors"; then
        log_info "OpenDKIM configuration is valid"
    else
        log_warning "OpenDKIM configuration test had warnings, but continuing..."
    fi
    
    # Start OpenDKIM
    log_info "Starting OpenDKIM service..."
    
    # Try to start with timeout
    timeout 15 systemctl start opendkim 2>/dev/null
    
    # Check if started
    sleep 2
    if systemctl is-active --quiet opendkim; then
        log_info "OpenDKIM started successfully"
        systemctl enable opendkim 2>/dev/null
        
        # Verify socket
        if [ -S "$SOCKET_DIR/opendkim.sock" ]; then
            log_info "OpenDKIM socket created: $SOCKET_DIR/opendkim.sock"
            chmod 660 "$SOCKET_DIR/opendkim.sock"
            chown opendkim:postfix "$SOCKET_DIR/opendkim.sock"
        else
            log_warning "OpenDKIM socket not found, but service is running"
        fi
        
        return 0
    else
        log_warning "OpenDKIM failed to start via systemd"
        
        # Try manual start for debugging
        log_info "Attempting manual start to see errors..."
        if su -s /bin/bash -c "opendkim -f -x $OPENDKIM_CONF" opendkim & then
            local PID=$!
            sleep 3
            if kill -0 $PID 2>/dev/null; then
                log_info "OpenDKIM running manually with PID $PID"
                # Create systemd service file that works
                cat > /etc/systemd/system/opendkim.service <<'EOF'
[Unit]
Description=OpenDKIM Milter
After=network.target

[Service]
Type=forking
PIDFile=/run/opendkim/opendkim.pid
User=opendkim
Group=opendkim
ExecStart=/usr/sbin/opendkim -x /etc/opendkim.conf -P /run/opendkim/opendkim.pid
ExecReload=/bin/kill -HUP $MAINPID
KillMode=process
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
                mkdir -p /run/opendkim
                chown opendkim:opendkim /run/opendkim
                systemctl daemon-reload
                systemctl start opendkim
                return 0
            fi
        fi
        
        log_error "OpenDKIM manual start also failed"
        return 1
    fi
}

