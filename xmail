#!/bin/bash

# ============================================================================
# MailX Server Installation Script - Production Ready
# With Idempotent Operations and Resume Capability
# ============================================================================

set +e

# ============================================================================
# Global Variables and Configuration
# ============================================================================

STATE_DIR="/usr/local/mailx_state"
LOG_DIR="/var/log/mailx"
LOG_FILE="$LOG_DIR/installation.log"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Create necessary directories
mkdir -p "$STATE_DIR" "$LOG_DIR"

# Enable logging
exec > >(tee -a "$LOG_FILE") 2>&1

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# ============================================================================
# Utility Functions
# ============================================================================

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

mark_stage_complete() {
    local stage=$1
    echo "$(date +%Y-%m-%d_%H:%M:%S)" > "$STATE_DIR/${stage}.completed"
    log_info "Stage '$stage' marked as complete"
}

is_stage_completed() {
    local stage=$1
    [ -f "$STATE_DIR/${stage}.completed" ]
}

file_exists_and_not_empty() {
    [ -f "$1" ] && [ -s "$1" ]
}

is_service_running() {
    systemctl is-active --quiet "$1" 2>/dev/null
}

is_package_installed() {
    dpkg -l "$1" 2>/dev/null | grep -q "^ii"
}

check_string_in_file() {
    local file=$1
    local string=$2
    grep -qF "$string" "$file" 2>/dev/null
}

generate_blowfish_secret() {
    tr -dc 'a-zA-Z0-9./' < /dev/urandom | fold -w 32 | head -n 1
}

generate_password() {
    local length=$1
    local chars="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local password=""
    for i in $(seq 1 $length); do
        password+=$(echo $chars | fold -w1 | shuf | head -n1)
    done
    echo $password
}

retrieve_file_data() {
    local filepath=$1
    if [ -f "$filepath" ]; then
        cat "$filepath"
    else
        log_error "Error: Password file $filepath not found."
        exit 1
    fi
}

# ============================================================================
# Enhanced Error Handling and Retry Logic
# ============================================================================

hide_output() {
    local OUTPUT=$(mktemp)
    set +e
    "$@" &> "$OUTPUT"
    local E=$?
    set -e
    
    if [ $E != 0 ]; then
        if grep -q "Could not resolve host\|Connection refused\|Connection timed out\|Network is unreachable" "$OUTPUT" 2>/dev/null; then
            log_warning "Network error detected: $(cat "$OUTPUT" | head -1)"
            rm -f "$OUTPUT"
            return 1
        elif grep -q "dpkg was interrupted\|dpkg --configure -a" "$OUTPUT" 2>/dev/null; then
            log_warning "Package manager interrupted. Running dpkg --configure -a..."
            dpkg --configure -a
            rm -f "$OUTPUT"
            return 1
        else
            log_error "FAILED: $*"
            echo "----------------------------------------"
            cat "$OUTPUT"
            echo "----------------------------------------"
            rm -f "$OUTPUT"
            exit $E
        fi
    fi
    rm -f "$OUTPUT"
    return 0
}

retry_command() {
    local max_attempts=5
    local attempt=1
    local delay=10
    local command="$@"
    
    while [ $attempt -le $max_attempts ]; do
        if eval "$command" 2>&1; then
            return 0
        fi
        
        log_warning "Command failed (attempt $attempt/$max_attempts). Retrying in $delay seconds..."
        sleep $delay
        attempt=$((attempt + 1))
        delay=$((delay * 2))
    done
    
    log_error "Command failed after $max_attempts attempts: $command"
    return 1
}

apt_get_quiet() {
    DEBIAN_FRONTEND=noninteractive hide_output apt-get -y -o Dpkg::Options::="--force-confdef" -o Dpkg::Options::="--force-confnew" "$@"
}

apt_install() {
    log_info "Installing packages: $@"
    retry_command apt_get_quiet install "$@"
}

restart_service() {
    log_info "Restarting service: $1"
    hide_output service "$1" restart
}

# ============================================================================
# Configuration Functions
# ============================================================================

update_php_ini() {
    local setting=$1
    local value=$2
    local ini_file=$3
    
    if [ -f "$ini_file" ]; then
        if grep -q "^${setting} = " "$ini_file"; then
            sed -i "s/^${setting} = .*/${setting} = ${value}/" "$ini_file"
        else
            echo "${setting} = ${value}" >> "$ini_file"
        fi
    fi
}

configure_dovecot_quota() {
    if [ -f "/etc/dovecot/conf.d/90-quota.conf" ]; then
        log_info "Dovecot quota already configured, skipping..."
        return 0
    fi
    
    log_info "Configuring Dovecot for quota support..."
    
    # Backup existing configuration files
    cp /etc/dovecot/dovecot.conf /etc/dovecot/dovecot.conf.bak 2>/dev/null || true
    cp /etc/dovecot/conf.d/10-mail.conf /etc/dovecot/conf.d/10-mail.conf.bak 2>/dev/null || true
    
    # Enable maildir format
    new_mail_location="mbox:~/mail:INBOX=/var/mail/%u"
    escaped_mail_location=$(echo "$new_mail_location" | sed 's/\//\\\//g')
    sed -i "s/^mail_location = .*$/mail_location = $escaped_mail_location/" /etc/dovecot/conf.d/10-mail.conf 2>/dev/null || true
    
    # Enable quota support
    cat <<EOT > /etc/dovecot/conf.d/90-quota.conf
plugin {
  quota = maildir:User quota
  quota_rule = *:storage=1G
}

protocol imap {
  mail_plugins = \$mail_plugins quota
}

protocol pop3 {
  mail_plugins = \$mail_plugins quota
}
EOT
    
    log_info "Dovecot quota configuration complete."
}

configure_dovecot_sasl() {
    if [ -f "/etc/dovecot/conf.d/10-master.conf" ] && [ -S "/var/spool/postfix/private/auth" ]; then
        log_info "Dovecot SASL already configured, skipping..."
        return 0
    fi
    
    log_info "Configuring Dovecot SASL..."
    
    # Install required packages
    apt_install dovecot-sieve dovecot-managesieved sasl2-bin
    
    # Create vmail user if not exists
    if ! id vmail >/dev/null 2>&1; then
        groupadd -g 5000 vmail
        useradd -g vmail -u 5000 vmail -d /var/mail/vmail -m
        chown -R vmail:vmail /var/mail/vmail
    fi
    
    # Create auth directory structure
    mkdir -p /var/spool/postfix/private
    chown -R postfix:postfix /var/spool/postfix/private
    chmod -R 0750 /var/spool/postfix/private
    
    # Remove any existing auth socket/directory
    [ -e /var/spool/postfix/private/auth ] && rm -rf /var/spool/postfix/private/auth
    
    # Configure 10-master.conf
    cat <<EOF > /etc/dovecot/conf.d/10-master.conf
service auth {
  unix_listener /var/spool/postfix/private/auth {
    mode = 0660
    user = postfix
    group = postfix
  }
}

service imap-login {
  inet_listener imap {
    port = 143
  }
  inet_listener imaps {
    port = 993
    ssl = yes
  }
}

service pop3-login {
  inet_listener pop3 {
    port = 110
  }
  inet_listener pop3s {
    port = 995
    ssl = yes
  }
}

service lmtp {
  unix_listener lmtp {
    mode = 0660
    user = postfix
    group = postfix
  }
}

service auth-worker {
  user = root
}
EOF
    
    # Basic auth configuration
    cat <<EOF > /etc/dovecot/conf.d/10-auth.conf
disable_plaintext_auth = no
auth_mechanisms = plain login
!include auth-system.conf.ext
EOF
    
    # Mail location configuration
    cat <<EOF > /etc/dovecot/conf.d/10-mail.conf
mail_location = maildir:~/Maildir

namespace inbox {
  inbox = yes
  mailbox Drafts {
    auto = subscribe
    special_use = \\Drafts
  }
  mailbox Junk {
    auto = subscribe
    special_use = \\Junk
  }
  mailbox Sent {
    auto = subscribe
    special_use = \\Sent
  }
  mailbox Trash {
    auto = subscribe
    special_use = \\Trash
  }
}
EOF
    
    # Validate configuration
    if ! dovecot -n 2>/dev/null; then
        log_warning "Dovecot configuration validation failed, but continuing..."
    fi
    
    # Restart Dovecot
    systemctl stop dovecot 2>/dev/null || true
    sleep 2
    systemctl start dovecot || {
        log_error "Dovecot failed to start. Check logs: journalctl -u dovecot -n 20"
        return 1
    }
    
    # Verify socket creation
    if [ -S /var/spool/postfix/private/auth ]; then
        log_info "Dovecot SASL configured successfully"
    else
        log_warning "SASL socket not created immediately, may need manual check"
    fi
    
    # Restart Postfix
    systemctl restart postfix 2>/dev/null || true
}

verify_postfix_dovecot_connection() {
    log_info "Verifying Postfix-Dovecot SASL connection..."
    if sudo -u postfix ls /var/spool/postfix/private/auth >/dev/null 2>&1; then
        log_info "Postfix can access Dovecot auth socket - configuration OK"
        return 0
    else
        log_warning "Postfix cannot access Dovecot auth socket"
        return 1
    fi
}

test_sasl_authentication() {
    log_info "Testing SASL authentication..."
    echo "auth plain" | nc -w 2 localhost 587 2>/dev/null | grep -q "VXNlcm5hbWU6" && \
        log_info "SASL PLAIN authentication available" || \
        log_warning "SASL PLAIN authentication NOT available"
    
    echo "auth login" | nc -w 2 localhost 587 2>/dev/null | grep -q "VXNlcm5hbWU6" && \
        log_info "SASL LOGIN authentication available" || \
        log_warning "SASL LOGIN authentication NOT available"
}

update_postfix_config() {
    local domain="$1"
    local hostname="$2"
    local config_dir="/etc/postfix"
    local backup_dir="${config_dir}/backups"
    local timestamp=$(date +%Y%m%d_%H%M%S)
    
    if [ -f "$config_dir/main.cf" ] && grep -q "$domain" "$config_dir/main.cf" 2>/dev/null; then
        log_info "Postfix already configured for domain $domain, skipping..."
        return 0
    fi
    
    log_info "Updating Postfix configuration for domain: $domain, hostname: $hostname"
    
    # Create backup directory
    mkdir -p "$backup_dir"
    
    # Backup original configuration files
    for file in main.cf master.cf; do
        if [[ -f "${config_dir}/${file}" ]]; then
            cp -p "${config_dir}/${file}" "${backup_dir}/${file}.bak_${timestamp}" 2>/dev/null || true
        fi
    done
    
    # Download configuration files
    declare -A config_urls=(
        ["main.cf"]="https://raw.githubusercontent.com/gtmylab/mailx/main/postfix_main.cf"
        ["master.cf"]="https://raw.githubusercontent.com/gtmylab/mailx/main/postfix_master.cf"
    )
    
    for file in "${!config_urls[@]}"; do
        url="${config_urls[$file]}"
        log_info "Downloading $file from $url"
        
        if retry_command "wget -q --timeout=30 --tries=3 -O ${config_dir}/${file}.tmp $url"; then
            if [[ -s "${config_dir}/${file}.tmp" ]]; then
                mv "${config_dir}/${file}.tmp" "${config_dir}/${file}"
                log_info "Successfully downloaded $file"
            else
                log_error "Downloaded file is empty: $file"
                return 1
            fi
        else
            log_error "Failed to download $file"
            return 1
        fi
    done
    
    # Replace placeholders
    for file in main.cf master.cf; do
        if [[ -f "${config_dir}/${file}" ]]; then
            sed -i.bak "s/{EMAIL_DOMAIN}/$domain/g; s/{HOSTNAME}/$hostname/g" "${config_dir}/${file}" 2>/dev/null || true
        fi
    done
    
    # Create access files
    mkdir -p "$(dirname "$config_dir/helo_access")"
    
    if [[ ! -f "$config_dir/helo_access" ]]; then
        echo "$hostname OK" > "$config_dir/helo_access"
        echo ".$domain OK" >> "$config_dir/helo_access"
        postmap "$config_dir/helo_access" 2>/dev/null || true
    fi
    
    if [[ ! -f "$config_dir/virtual_domains" ]]; then
        echo "$domain OK" > "$config_dir/virtual_domains"
        postmap "$config_dir/virtual_domains" 2>/dev/null || true
    fi
    
    # Validate configuration
    if postfix check 2>/dev/null; then
        log_info "Postfix configuration validated"
    else
        log_warning "Postfix configuration check had warnings"
    fi
    
    # Restart Postfix
    restart_service postfix
    return 0
}

update_postfix_virtual() {
    local domain=$1
    local username=$2
    
    if ! check_string_in_file "/etc/postfix/virtual" "$username@$domain"; then
        echo "$username@$domain $username" >> /etc/postfix/virtual
        postmap /etc/postfix/virtual 2>/dev/null
        log_info "Updated /etc/postfix/virtual with $username@$domain"
    fi
}

update_postfix_maincf() {
    local domain=$1
    
    if grep -q "virtual_alias_domains = .*$domain" /etc/postfix/main.cf 2>/dev/null; then
        log_info "Postfix main.cf already configured for domain $domain, skipping..."
        return 0
    fi
    
    if ! check_string_in_file "/etc/postfix/main.cf" "virtual_alias_domains"; then
        echo "virtual_alias_domains = $domain" >> /etc/postfix/main.cf 2>/dev/null
    else
        sed -i "/^virtual_alias_domains/c\virtual_alias_domains = $domain" /etc/postfix/main.cf 2>/dev/null
    fi
    
    if ! check_string_in_file "/etc/postfix/main.cf" "virtual_alias_maps"; then
        echo "virtual_alias_maps = hash:/etc/postfix/virtual" >> /etc/postfix/main.cf 2>/dev/null
    fi
    
    if ! check_string_in_file "/etc/postfix/main.cf" "mydomain"; then
        echo "mydomain = $domain" >> /etc/postfix/main.cf 2>/dev/null
    else
        sed -i "/^mydomain/c\mydomain = $domain" /etc/postfix/main.cf 2>/dev/null
    fi
    
    if ! check_string_in_file "/etc/postfix/main.cf" "myorigin"; then
        echo "myorigin = \$mydomain" >> /etc/postfix/main.cf 2>/dev/null
    else
        sed -i "/^myorigin/c\myorigin = \$mydomain" /etc/postfix/main.cf 2>/dev/null
    fi
    
    if ! check_string_in_file "/etc/postfix/main.cf" "mydestination"; then
        echo "mydestination = \$myhostname, localhost.\$mydomain, localhost, \$mydomain" >> /etc/postfix/main.cf 2>/dev/null
    else
        sed -i "/^mydestination/c\mydestination = \$myhostname, localhost.\$mydomain, localhost, \$mydomain" /etc/postfix/main.cf 2>/dev/null
    fi
}

setup_postfix_header_checks() {
    local hostname=$1
    
    if [ -f "/etc/postfix/header_checks" ]; then
        log_info "Postfix header checks already configured, skipping..."
        return 0
    fi
    
    log_info "Configuring Postfix header checks..."
    
    cat <<EOF > /etc/postfix/header_checks
/^Received: from \S+ \(.*\[.*\]\)/ REPLACE Received: from $hostname (localhost [127.0.0.1])
/^X-Originating-IP:/ IGNORE
EOF
    
    if ! grep -q "header_checks" /etc/postfix/main.cf 2>/dev/null; then
        echo "header_checks = regexp:/etc/postfix/header_checks" >> /etc/postfix/main.cf
    fi
    
    chmod 644 /etc/postfix/header_checks
    log_info "Postfix header checks configured successfully."
}

setup_phpmyadmin() {
    # Check if already properly installed
    if [ -d "/var/www/html/phpmyadmin" ] && [ -f "/var/www/html/phpmyadmin/config.inc.php" ]; then
        log_info "PHPMyAdmin already installed, skipping..."
        return 0
    fi
    
    log_info "Installing phpMyAdmin..."
    
    PMA_VERSION="5.1.1"
    PMA_DIR="/var/www/html/phpmyadmin"
    PMA_URL="https://files.phpmyadmin.net/phpMyAdmin/${PMA_VERSION}/phpMyAdmin-${PMA_VERSION}-all-languages.tar.gz"
    PMA_TAR="phpMyAdmin-${PMA_VERSION}-all-languages.tar.gz"
    PMA_TAR_DIR="phpMyAdmin-${PMA_VERSION}-all-languages"
    
    # Save current directory
    local CURRENT_DIR=$(pwd)
    cd /tmp || {
        log_error "Failed to change to /tmp directory"
        return 1
    }
    
    # Clean up any existing temp files (with error suppression)
    rm -rf "$PMA_TAR_DIR" 2>/dev/null || true
    rm -f "$PMA_TAR" 2>/dev/null || true
    
    # Download with retry and verification
    log_info "Downloading phpMyAdmin version $PMA_VERSION..."
    local download_success=false
    
    for i in {1..3}; do
        if wget -q --timeout=30 --tries=3 "$PMA_URL" -O "$PMA_TAR" 2>/dev/null; then
            if [ -s "$PMA_TAR" ]; then
                download_success=true
                break
            fi
        fi
        log_warning "Download attempt $i failed, retrying..."
        sleep 5
    done
    
    if [ "$download_success" != "true" ]; then
        log_error "Failed to download phpMyAdmin after multiple attempts"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi
    
    # Extract
    log_info "Extracting phpMyAdmin..."
    if ! tar -xzf "$PMA_TAR" 2>/dev/null; then
        log_error "Failed to extract phpMyAdmin"
        rm -f "$PMA_TAR" 2>/dev/null || true
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi
    
    # Verify extraction
    if [ ! -d "$PMA_TAR_DIR" ]; then
        log_error "Extraction failed - directory not found"
        rm -f "$PMA_TAR" 2>/dev/null || true
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi
    
    # Handle existing installation - check if it's a valid installation first
    if [ -d "$PMA_DIR" ]; then
        # If it has config file, it might be valid
        if [ -f "$PMA_DIR/config.inc.php" ]; then
            log_info "Existing phpMyAdmin installation found with config, keeping it"
            # Clean up temp files
            rm -rf "$PMA_TAR_DIR" 2>/dev/null || true
            rm -f "$PMA_TAR" 2>/dev/null || true
            cd "$CURRENT_DIR" 2>/dev/null || true
            return 0
        else
            # Incomplete installation, remove it
            log_info "Removing incomplete phpMyAdmin directory..."
            rm -rf "$PMA_DIR" 2>/dev/null || true
        fi
    fi
    
    # Move to final location
    log_info "Moving phpMyAdmin to $PMA_DIR..."
    if ! mv "$PMA_TAR_DIR" "$PMA_DIR" 2>/dev/null; then
        log_error "Failed to move phpMyAdmin to final location"
        rm -rf "$PMA_TAR_DIR" 2>/dev/null || true
        rm -f "$PMA_TAR" 2>/dev/null || true
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi
    
    # Clean up temp file
    rm -f "$PMA_TAR" 2>/dev/null || true
    
    # Generate secret
    SECRET=$(generate_blowfish_secret)
    
    # Create config file
    log_info "Configuring phpMyAdmin..."
    if [ -f "$PMA_DIR/config.sample.inc.php" ]; then
        cp "$PMA_DIR/config.sample.inc.php" "$PMA_DIR/config.inc.php" 2>/dev/null || {
            log_error "Failed to copy config sample"
            cd "$CURRENT_DIR" 2>/dev/null || true
            return 1
        }
        sed -i "s|\(\$cfg\['blowfish_secret'\]\).*|\1 = '$SECRET';|" "$PMA_DIR/config.inc.php" 2>/dev/null || true
    else
        log_warning "Config sample not found, creating default config..."
        cat > "$PMA_DIR/config.inc.php" <<'EOF'
<?php
$cfg['blowfish_secret'] = '';
$i = 0;
$i++;
$cfg['Servers'][$i]['auth_type'] = 'cookie';
$cfg['Servers'][$i]['host'] = 'localhost';
$cfg['Servers'][$i]['compress'] = false;
$cfg['Servers'][$i]['AllowNoPassword'] = false;
?>
EOF
        # Insert the secret
        sed -i "s/\(\$cfg\['blowfish_secret'\] = \)'';/\1'$SECRET';/" "$PMA_DIR/config.inc.php" 2>/dev/null || true
    fi
    
    # Set permissions with error suppression
    log_info "Setting permissions..."
    chown -R www-data:www-data "$PMA_DIR" 2>/dev/null || true
    find "$PMA_DIR" -type d -exec chmod 755 {} \; 2>/dev/null || true
    find "$PMA_DIR" -type f -exec chmod 644 {} \; 2>/dev/null || true
    
    # Return to original directory
    cd "$CURRENT_DIR" 2>/dev/null || true
    
    # Verify installation
    if [ -f "$PMA_DIR/config.inc.php" ]; then
        log_info "PHPMyAdmin installation completed successfully"
        return 0
    else
        log_error "PHPMyAdmin installation verification failed - config file missing"
        return 1
    fi
}

# Add this function to safely execute stages
execute_stage() {
    local stage_name=$1
    local stage_function=$2
    shift 2
    
    if is_stage_completed "$stage_name"; then
        log_info "Stage '$stage_name' already completed, skipping..."
        return 0
    fi
    
    log_info "=== Stage: $stage_name ==="
    
    # Temporarily disable exit on error
    set +e
    
    # Execute the stage function
    if $stage_function "$@"; then
        local exit_code=$?
        set -e
        if [ $exit_code -eq 0 ]; then
            mark_stage_complete "$stage_name"
            log_info "Stage '$stage_name' completed successfully"
            return 0
        else
            log_error "Stage '$stage_name' failed with exit code $exit_code"
            set -e
            return 1
        fi
    else
        local exit_code=$?
        set -e
        log_error "Stage '$stage_name' failed with exit code $exit_code"
        return 1
    fi
}



# Add this function to handle file operations safely
safe_move_or_copy() {
    local source=$1
    local dest=$2
    
    if [ -d "$source" ]; then
        # If destination exists and is not empty, merge
        if [ -d "$dest" ] && [ "$(ls -A "$dest" 2>/dev/null)" ]; then
            log_info "Destination exists, copying files..."
            cp -r "$source"/* "$dest/" 2>/dev/null || true
        else
            # If destination doesn't exist or is empty, move
            if [ -d "$dest" ]; then
                rm -rf "$dest"
            fi
            mv "$source" "$dest"
        fi
    else
        log_error "Source directory not found: $source"
        return 1
    fi
    return 0
}

