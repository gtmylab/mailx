UserID                  opendkim:opendkim
EOF
    
    # Create SigningTable (needed for multiple domains, but keep simple)
    cat > /etc/opendkim/SigningTable <<EOF
*@$DOMAIN $SELECTOR._domainkey.$DOMAIN
EOF
    
    # Create KeyTable
    cat > /etc/opendkim/KeyTable <<EOF
$SELECTOR._domainkey.$DOMAIN $DOMAIN:$SELECTOR:/etc/opendkim/keys/$DOMAIN/$SELECTOR.private
EOF
    
    # Set permissions
    chmod 644 /etc/opendkim.conf
    chmod 644 /etc/opendkim/SigningTable
    chmod 644 /etc/opendkim/KeyTable
    
    # Create systemd service that works
    cat > /etc/systemd/system/opendkim.service <<'EOF'
[Unit]
Description=OpenDKIM Milter
After=network.target

[Service]
Type=simple
User=opendkim
Group=opendkim
ExecStart=/usr/sbin/opendkim -x /etc/opendkim.conf -f
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF
    
    # Reload systemd
    systemctl daemon-reload
    
    # Kill any existing opendkim processes
    pkill -f opendkim 2>/dev/null || true
    rm -f /var/spool/postfix/opendkim/opendkim.sock 2>/dev/null || true
    
    # Start OpenDKIM
    log_info "Starting OpenDKIM..."
    systemctl start opendkim
    
    # Wait a moment
    sleep 3
    
    # Check if it's running
    if systemctl is-active --quiet opendkim; then
        log_info "OpenDKIM started successfully"
        
        # Check socket
        if [ -S "/var/spool/postfix/opendkim/opendkim.sock" ]; then
            log_info "Socket created: /var/spool/postfix/opendkim/opendkim.sock"
            ls -la /var/spool/postfix/opendkim/opendkim.sock
        else
            log_warning "Socket not created, checking logs..."
            journalctl -u opendkim -n 10 --no-pager
        fi
        
        # Enable service
        systemctl enable opendkim
        
        # Configure Postfix
        log_info "Configuring Postfix for DKIM..."
        postconf -e "milter_default_action = accept"
        postconf -e "milter_protocol = 2"
        postconf -e "smtpd_milters = unix:opendkim/opendkim.sock"
        postconf -e "non_smtpd_milters = unix:opendkim/opendkim.sock"
        
        # Restart Postfix
        systemctl restart postfix
        
        # Test DKIM (this may fail if DNS isn't set up yet)
        log_info "Testing DKIM key (may fail if DNS not configured)..."
        opendkim-testkey -d "$DOMAIN" -s "$SELECTOR" 2>&1 | head -2
        
        return 0
    else
        log_error "OpenDKIM failed to start. Checking logs..."
        journalctl -u opendkim -n 20 --no-pager
        
        # Try manual start to see error
        log_info "Attempting manual start to see error..."
        sudo -u opendkim /usr/sbin/opendkim -x /etc/opendkim.conf -f -v &
        sleep 3
        pgrep -f opendkim
        
        return 1
    fi
}

# Update the DKIM generation to use the simple config
generate_dkim_simple() {
    local DOMAIN=$1
    local SELECTOR="default"
    local DKIM_DIR="/etc/opendkim/keys/$DOMAIN"
    local KEY_FILE="$DKIM_DIR/$SELECTOR.private"
    
    # Check if key already exists
    if [ -f "$KEY_FILE" ]; then
        log_info "DKIM key already exists for domain $DOMAIN"
        
        # Extract DKIM record for email
        if [ -f "$DKIM_DIR/$SELECTOR.txt" ]; then
            DKIM_RECORD=$(cat "$DKIM_DIR/$SELECTOR.txt" | grep -o 'v=DKIM1;.*' | sed 's/"//g')
            echo "$DKIM_RECORD" > /tmp/dkim_txt_record.txt
            log_info "DKIM TXT record: $SELECTOR._domainkey.$DOMAIN = \"$DKIM_RECORD\""
        fi
        
        return 0
    fi
    
    log_info "Generating DKIM key for domain $DOMAIN..."
    
    # Create directory
    mkdir -p "$DKIM_DIR"
    cd "$DKIM_DIR"
    
    # Generate key
    if ! opendkim-genkey -s "$SELECTOR" -d "$DOMAIN" -b 2048; then
        log_error "Failed to generate DKIM key"
        return 1
    fi
    
    # Set permissions
    chown -R opendkim:opendkim "$DKIM_DIR"
    chmod 750 "$DKIM_DIR"
    chmod 600 "$SELECTOR.private"
    chmod 644 "$SELECTOR.txt"
    
    # Extract DKIM record
    DKIM_RECORD=$(cat "$SELECTOR.txt" | grep -o 'v=DKIM1;.*' | sed 's/"//g')
    echo "$DKIM_RECORD" > /tmp/dkim_txt_record.txt
    
    log_info "DKIM key generated successfully"
    log_info "DKIM TXT record: $SELECTOR._domainkey.$DOMAIN = \"$DKIM_RECORD\""
    
    cd - > /dev/null
    return 0
}

