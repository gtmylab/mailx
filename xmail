        rm -rf "$PMA_DIR"
    fi
    
    # Move to final location
    mv "$PMA_TAR_DIR" "$PMA_DIR"
    
    # Clean up temp file
    rm -f "$PMA_TAR"
    
    # Generate secret
    SECRET=$(generate_blowfish_secret)
    
    # Create config file
    if [ -f "$PMA_DIR/config.sample.inc.php" ]; then
        cp "$PMA_DIR/config.sample.inc.php" "$PMA_DIR/config.inc.php"
        sed -i "s|\(\$cfg\['blowfish_secret'\]\).*|\1 = '$SECRET';|" "$PMA_DIR/config.inc.php"
    else
        log_warning "Config sample not found, creating default config..."
        cat > "$PMA_DIR/config.inc.php" <<EOF
<?php
\$cfg['blowfish_secret'] = '$SECRET';
\$i = 0;
\$i++;
\$cfg['Servers'][\$i]['auth_type'] = 'cookie';
\$cfg['Servers'][\$i]['host'] = 'localhost';
\$cfg['Servers'][\$i]['compress'] = false;
\$cfg['Servers'][\$i]['AllowNoPassword'] = false;
?>
EOF
    fi
    
    # Set permissions
    chown -R www-data:www-data "$PMA_DIR"
    chmod -R 755 "$PMA_DIR"
    find "$PMA_DIR" -type f -exec chmod 644 {} \;
    
    cd - > /dev/null
    
