change_domain_hostname() {
    local old_domain=$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null || echo "")
    local old_hostname=$(hostname)
    
    if [ -z "$old_domain" ]; then
        log_error "No existing domain found"
        return 1
    fi
    
    echo "Current Domain: $old_domain"
    echo "Current Hostname: $old_hostname"
    echo
    
    read -p "Enter new email domain (e.g., example.com): " new_domain
    read -p "Enter new hostname (e.g., mail.example.com): " new_hostname
    
    if [[ -z "$new_domain" || -z "$new_hostname" ]]; then
        log_error "Both domain and hostname are required."
        return 1
    fi
    
    echo "$new_hostname" > /etc/hostname
    hostnamectl set-hostname "$new_hostname"
    sed -i "s/$old_hostname/$new_hostname/g" /etc/hosts
    
    echo "$new_hostname" > /etc/mailname
    echo "$new_domain" > /usr/local/roundcube_mail_domain.txt
    
    sed -i "s/$old_domain/$new_domain/g" /etc/postfix/main.cf 2>/dev/null || true
    sed -i "s/$old_hostname/$new_hostname/g" /etc/postfix/main.cf 2>/dev/null || true
    
    if [ -f "/etc/postfix/header_checks" ]; then
        sed -i "s/$old_hostname/$new_hostname/g" /etc/postfix/header_checks
    fi
    
    if [ -f "/var/www/html/roundcube/config/config.inc.php" ]; then
        sed -i "s/$old_domain/$new_domain/g" /var/www/html/roundcube/config/config.inc.php
        sed -i "s/mail_domain'] = .*/mail_domain'] = '$new_domain';/" /var/www/html/roundcube/config/config.inc.php
    fi
    
    for config_file in /etc/apache2/sites-available/*.conf; do
        [ -f "$config_file" ] && sed -i "s/$old_domain/$new_domain/g" "$config_file" 2>/dev/null || true
        [ -f "$config_file" ] && sed -i "s/$old_hostname/$new_hostname/g" "$config_file" 2>/dev/null || true
    done
    
    generate_dkim
    restart_service postfix
    restart_service dovecot
    restart_service apache2
    restart_service opendkim
    
    manage_ssl_certificates change "$new_domain"
    
    log_info "Domain changed successfully to $new_domain with hostname $new_hostname"
}

set_postfix_custom_port() {
    local current_port=$(postconf -h smtpd_port 2>/dev/null || echo "25")
    echo "Current Postfix SMTP port: $current_port"
    
    read -p "Enter new SMTP port number (recommended 587 or 465): " new_port
    
    if [[ ! "$new_port" =~ ^[0-9]+$ ]] || [ "$new_port" -lt 1 ] || [ "$new_port" -gt 65535 ]; then
        log_error "Invalid port number"
        return 1
    fi
    
    cp /etc/postfix/master.cf /etc/postfix/master.cf.bak
    cp /etc/postfix/main.cf /etc/postfix/main.cf.bak
    
    sed -i '/^smtp.*inet.*smtpd/d' /etc/postfix/master.cf
    sed -i '/^submission.*inet.*smtpd/d' /etc/postfix/master.cf
    sed -i '/^smtps.*inet.*smtpd/d' /etc/postfix/master.cf
    
    cat <<EOF >> /etc/postfix/master.cf
# Custom SMTP port
${new_port}      inet  n       -       y       -       -       smtpd
  -o syslog_name=postfix/smtp-custom
  -o smtpd_tls_security_level=may
  -o smtpd_sasl_auth_enable=yes
  -o smtpd_client_restrictions=permit_sasl_authenticated,reject
EOF
    
    postconf -e "smtpd_port=$new_port"
    postconf -e "alternate_smtp_ports=$new_port"
    
    if [ -f "/var/www/html/roundcube/config/config.inc.php" ]; then
        sed -i "s/\$config\['smtp_port'\] = .*/\$config\['smtp_port'\] = $new_port;/" /var/www/html/roundcube/config/config.inc.php
    fi
    
    if command -v ufw &>/dev/null; then
        ufw allow "$new_port"/tcp
        ufw delete allow 25/tcp 2>/dev/null || true
    fi
    
    restart_service postfix
    log_info "Postfix SMTP port changed to $new_port"
}

add_domain() {
    local domain=$1
    local domain_file="/usr/local/roundcube_mail_domain.txt"
    local helo_access_file="/etc/postfix/helo_access"
    local virtual_domains_file="/etc/postfix/virtual_domains"
    
    if check_string_in_file "$domain_file" "$domain"; then
        log_warning "Domain $domain already exists"
        return 1
    fi
    
    echo "$domain" >> "$domain_file"
    
    if [ ! -f "$helo_access_file" ]; then
        touch "$helo_access_file"
        chmod 640 "$helo_access_file"
        chown root:postfix "$helo_access_file"
    fi
    
    if ! grep -qF ".$domain OK" "$helo_access_file" 2>/dev/null; then
        echo ".$domain OK" >> "$helo_access_file"
        postmap "$helo_access_file" 2>/dev/null || true
    fi
    
    if [ ! -f "$virtual_domains_file" ]; then
        touch "$virtual_domains_file"
        chmod 640 "$virtual_domains_file"
        chown root:postfix "$virtual_domains_file"
    fi
    
    if ! grep -qF "$domain OK" "$virtual_domains_file" 2>/dev/null; then
        echo "$domain OK" >> "$virtual_domains_file"
        postmap "$virtual_domains_file" 2>/dev/null || true
    fi
    
    log_info "Domain $domain added successfully"
}

remove_domain() {
    local domain=$1
    local domain_file="/usr/local/roundcube_mail_domain.txt"
    local helo_access_file="/etc/postfix/helo_access"
    local virtual_domains_file="/etc/postfix/virtual_domains"
    local temp_file=$(mktemp)
    
    local domain_count=$(wc -l < "$domain_file" | tr -d ' ')
    if [ "$domain_count" -le 1 ]; then
        log_error "Cannot remove the last domain"
        return 1
    fi
    
    if ! check_string_in_file "$domain_file" "$domain"; then
        log_error "Domain $domain does not exist"
        return 1
    fi
    
    grep -v "^$domain$" "$domain_file" > "$temp_file"
    mv "$temp_file" "$domain_file"
    
    if [ -f "$helo_access_file" ]; then
        grep -vF ".$domain OK" "$helo_access_file" > "$temp_file"
        mv "$temp_file" "$helo_access_file"
        postmap "$helo_access_file" 2>/dev/null || true
    fi
    
    if [ -f "$virtual_domains_file" ]; then
        grep -vF "$domain OK" "$virtual_domains_file" > "$temp_file"
        mv "$temp_file" "$virtual_domains_file"
        postmap "$virtual_domains_file" 2>/dev/null || true
    fi
    
    log_info "Domain $domain removed successfully"
}

