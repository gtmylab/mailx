# Enhanced verify_dkim function
verify_dkim() {
    local DOMAIN=$(retrieve_file_data /usr/local/roundcube_mail_domain.txt)
    local SELECTOR="default"
    
    log_info "Verifying DKIM configuration..."
    
    # Wait a moment for service to stabilize
    sleep 2
    
    # Check if OpenDKIM is running
    if systemctl is-active --quiet opendkim; then
        log_info "OpenDKIM is running"
        
        # Test the key
        if opendkim-testkey -d "$DOMAIN" -s "$SELECTOR" 2>&1 | grep -q "key OK"; then
            log_info "DKIM key verification successful"
            return 0
        else
            log_warning "DKIM key verification failed. DNS may not have propagated yet."
            log_info "Test with: opendkim-testkey -d $DOMAIN -s $SELECTOR -vvv"
            return 1
        fi
    else
        log_warning "OpenDKIM is not running"
        
        # Check service status
        if systemctl status opendkim --no-pager -l; then
            log_info "Service status displayed above"
        fi
        
        log_info "Attempting to start OpenDKIM manually..."
        
        # Try to start with specific config
        if opendkim -f -x /etc/opendkim.conf; then
            log_info "OpenDKIM started manually"
            systemctl start opendkim 2>/dev/null || true
            return 0
        else
            log_error "OpenDKIM cannot start. Check configuration:"
            log_error "opendkim -f -x /etc/opendkim.conf"
            return 1
        fi
    fi
}

