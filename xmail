# Fixed generate_dkim with proper error handling
generate_dkim() {
    DOMAIN=$(retrieve_file_data /usr/local/roundcube_mail_domain.txt)
    SELECTOR="default"
    DKIM_DIR="/etc/opendkim"
    KEY_DIR="$DKIM_DIR/keys/$DOMAIN"
    KEY_FILE="$KEY_DIR/$SELECTOR.private"
    TXT_RECORD_FILE="$KEY_DIR/$SELECTOR.txt"
    
    # Check if OpenDKIM is installed
    if ! command -v opendkim-genkey &> /dev/null; then
        log_info "Installing OpenDKIM..."
        apt_install opendkim opendkim-tools
    fi
    
    # Ensure opendkim user exists
    if ! id opendkim &>/dev/null; then
        useradd -r -s /usr/sbin/nologin opendkim
    fi
    
    # Create necessary directories
    sudo mkdir -p "$KEY_DIR"
    
    # Check if key already exists and is valid
    if [ -f "$KEY_FILE" ]; then
        log_info "DKIM key already exists for domain $DOMAIN"
        
        # Verify key file permissions
        sudo chown opendkim:opendkim "$KEY_FILE" 2>/dev/null || true
        sudo chmod 600 "$KEY_FILE" 2>/dev/null || true
        
        # Try to extract existing TXT record
        if [ -f "$TXT_RECORD_FILE" ]; then
            DKIM_TXT_RECORD=$(cat "$TXT_RECORD_FILE" | grep -oP '(?<=v=DKIM1;).*' | sed 's/"//g' | sed 's/;//g' || echo "")
            if [ -n "$DKIM_TXT_RECORD" ]; then
                echo "$DKIM_TXT_RECORD" > /tmp/dkim_txt_record.txt
                log_info "Existing DKIM TXT record: $SELECTOR._domainkey.$DOMAIN"
            fi
        fi
        
        # Configure OpenDKIM (even if key exists)
        configure_opendkim "$DOMAIN" "$SELECTOR"
        return 0
    fi
    
    log_info "Generating DKIM key for domain $DOMAIN..."
    
    # Generate DKIM key with proper permissions
    cd "$KEY_DIR" || {
        log_error "Failed to change to key directory"
        return 1
    }
    
    # Remove any existing files
    rm -f "$SELECTOR.private" "$SELECTOR.txt" 2>/dev/null || true
    
    # Generate the key
    if ! sudo opendkim-genkey -s $SELECTOR -d $DOMAIN -b 2048; then
        log_error "Failed to generate DKIM key"
        cd - > /dev/null
        return 1
    fi
    
    # Fix permissions
    sudo chown opendkim:opendkim "$SELECTOR.private" "$SELECTOR.txt" 2>/dev/null || true
    sudo chmod 600 "$SELECTOR.private"
    sudo chmod 644 "$SELECTOR.txt"
    
    # Extract and format DKIM TXT record
    if [ -f "$SELECTOR.txt" ]; then
        # Extract the actual TXT record value
        DKIM_RAW=$(cat "$SELECTOR.txt" | grep -oP '(?<=v=DKIM1;).*' | sed 's/"//g' | sed 's/;//g' | tr -d '\n')
        
        if [ -n "$DKIM_RAW" ]; then
            # Create proper TXT record format
            DKIM_TXT_RECORD="v=DKIM1; h=sha256; k=rsa; p=$DKIM_RAW"
            
            # Save for later use
            echo "$DKIM_TXT_RECORD" > /tmp/dkim_txt_record.txt
            
            log_info "DKIM key generated successfully"
            log_info "DKIM TXT record:"
            log_info "$SELECTOR._domainkey.$DOMAIN IN TXT \"$DKIM_TXT_RECORD\""
        else
            log_error "Failed to extract DKIM TXT record"
        fi
    else
        log_error "DKIM TXT record file not found"
        cd - > /dev/null
        return 1
    fi
    
    cd - > /dev/null
    
    # Configure OpenDKIM
    if ! configure_opendkim "$DOMAIN" "$SELECTOR"; then
        log_warning "OpenDKIM configuration had issues, but key was generated"
    fi
    
    # Verify key files exist
    if [ -f "$KEY_FILE" ] && [ -f "$TXT_RECORD_FILE" ]; then
        log_info "DKIM key files created successfully"
        return 0
    else
        log_error "DKIM key files not created properly"
        return 1
    fi
}

configure_ssl_services() {
    local domain=$1
    local cert_path="/etc/letsencrypt/live/$domain"
    
    if [ ! -d "$cert_path" ]; then
        log_warning "SSL certificate not found for $domain, skipping service configuration"
        return 1
    fi
    
    # Apache configuration
    if [ -f "/etc/apache2/sites-available/adminportal.conf" ]; then
        sed -i "s|SSLCertificateFile.*|SSLCertificateFile $cert_path/fullchain.pem|" /etc/apache2/sites-available/adminportal.conf 2>/dev/null || true
        sed -i "s|SSLCertificateKeyFile.*|SSLCertificateKeyFile $cert_path/privkey.pem|" /etc/apache2/sites-available/adminportal.conf 2>/dev/null || true
    fi
    
    # Postfix configuration
    postconf -e "smtpd_tls_cert_file=$cert_path/fullchain.pem" 2>/dev/null || true
    postconf -e "smtpd_tls_key_file=$cert_path/privkey.pem" 2>/dev/null || true
    
    # Dovecot configuration
    if [ -f "/etc/dovecot/conf.d/10-ssl.conf" ]; then
        sed -i "s|ssl_cert =.*|ssl_cert = <$cert_path/fullchain.pem|" /etc/dovecot/conf.d/10-ssl.conf 2>/dev/null || true
        sed -i "s|ssl_key =.*|ssl_key = <$cert_path/privkey.pem|" /etc/dovecot/conf.d/10-ssl.conf 2>/dev/null || true
    fi
    
    log_info "SSL services configured for domain $domain"
}

setup_ssl_renewal() {
    if [ -f "/usr/local/bin/ssl_renewal.sh" ]; then
        log_info "SSL renewal already configured, skipping..."
        return 0
    fi
    
    cat << 'EOF' > /usr/local/bin/ssl_renewal.sh
#!/bin/bash
certbot renew --quiet --post-hook "systemctl reload postfix dovecot apache2"
EOF
    
    chmod +x /usr/local/bin/ssl_renewal.sh
    (crontab -l 2>/dev/null | grep -v "ssl_renewal.sh"; echo "0 3 * * * /usr/local/bin/ssl_renewal.sh") | crontab - 2>/dev/null || true
    
    log_info "Automatic SSL renewal configured."
}

manage_ssl_certificates() {
    local action=$1
    local domain=${2:-$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null || echo "")}
    local webroot="/var/www/html"
    
    if [ -z "$domain" ]; then
        log_error "No domain specified for SSL certificate"
        return 1
    fi
    
    case "$action" in
        install)
            if [ -d "/etc/letsencrypt/live/$domain" ]; then
                log_info "SSL certificate already installed for $domain"
                configure_ssl_services "$domain"
                return 0
            fi
            
            if ! command -v certbot &> /dev/null; then
                log_info "Installing certbot..."
                apt_install certbot python3-certbot-apache
            fi
            
            mkdir -p "$webroot/.well-known/acme-challenge"
            chown -R www-data:www-data "$webroot"
            
            log_info "Attempting to install Let's Encrypt SSL certificate for $domain..."
            
            if retry_command "certbot certonly --webroot -w $webroot -d $domain -d mail.$domain --non-interactive --agree-tos --email admin@$domain --keep-until-expiring"; then
                configure_ssl_services "$domain"
                setup_ssl_renewal
                log_info "SSL certificate installed successfully"
                return 0
            else
                log_error "Failed to obtain SSL certificate"
                return 1
            fi
            ;;
            
        renew)
            log_info "Renewing SSL certificates..."
            certbot renew --quiet --post-hook "systemctl reload postfix dovecot apache2" || true
            ;;
            
        change)
            local new_domain=$2
            if [[ -z "$new_domain" ]]; then
                log_error "New domain not specified"
                return 1
            fi
            
            log_info "Changing SSL certificate from $domain to $new_domain..."
            certbot certonly --webroot -w "$webroot" -d "$new_domain" -d "mail.$new_domain" \
                --non-interactive --agree-tos --email admin@$new_domain --keep-until-expiring --force-renewal || true
            
            configure_ssl_services "$new_domain"
            ;;
            
        *)
            log_error "Usage: manage_ssl_certificates [install|renew|change newdomain.com]"
            return 1
            ;;
    esac
}

add_roundcube_user() {
    local username=$1
    local password=$2
    local quota_size=$3
    local domain=$(retrieve_file_data /usr/local/roundcube_mail_domain.txt)
    local email="$username@$domain"
    local ROUNDCUBE_DB_PASSWORD=$(retrieve_file_data /usr/local/roundcube_db_pwd.txt)
    local ROUNDCUBE_DB_USER="roundcube"
    local ROUNDCUBE_DB_NAME="roundcubemail"
    
    # Check if user already exists
    if id "$username" >/dev/null 2>&1; then
        log_info "User $username already exists, skipping creation..."
        return 0
    fi
    
    # Create system user
    useradd -m -s /bin/bash "$username"
    echo "$username:$password" | chpasswd
    
    # Create Maildir
    mkdir -p "/home/$username/Maildir/"{cur,new,tmp}
    chown -R "$username:$username" "/home/$username/Maildir"
    
    # Configure Dovecot quota
    echo "quota_rule = *:storage=${quota_size}M" > "/home/$username/.dovecot.quota"
    chown "$username:$username" "/home/$username/.dovecot.quota"
    
    # Add to Postfix virtual maps
    echo "$email $username" >> /etc/postfix/virtual
    postmap /etc/postfix/virtual
    
    ROUNDCUBE_PREFERENCE='a:6:{s:14:"compose_extwin";i:1;s:10:"htmleditor";i:1;s:11:"mdn_default";b:0;s:11:"dsn_default";b:0;s:13:"sig_separator";b:0;s:25:"compose_save_localstorage";i:1;}'
    
    USER_ID=$(mysql $ROUNDCUBE_DB_NAME -se "INSERT INTO users (username, mail_host, created, last_login, language, preferences) VALUES ('$username', 'localhost', NOW(), NOW(), 'en_GB', '$ROUNDCUBE_PREFERENCE'); SELECT LAST_INSERT_ID();" 2>/dev/null || echo "")
    
    if [ -n "$USER_ID" ]; then
        mysql $ROUNDCUBE_DB_NAME -e "INSERT INTO identities (user_id, changed, del, standard, name, organization, email, \`reply-to\`, signature, html_signature) VALUES ('$USER_ID', NOW(), '0', '1', '$username', 'localhost', '$email', '$email', '', '1');" 2>/dev/null || true
    fi
    
    systemctl restart postfix dovecot 2>/dev/null || true
    
    send_welcome_email "$email" "$username"
    
    log_info "User $username created successfully with email $email"
}

