show_dkim_record() {
    local DOMAIN=""
    if [ -f /usr/local/roundcube_mail_domain.txt ]; then
        DOMAIN=$(cat /usr/local/roundcube_mail_domain.txt | tr -d '[:space:]')
    fi
    local SELECTOR="default"

    if [ -z "$DOMAIN" ]; then
        log_error "No domain configured. Run the installer first."
        return 1
    fi

    echo
    echo "=== DKIM Record for $DOMAIN ==="
    echo

    # Try multiple locations: generated file, persistent cache, temp cache
    local DKIM_RECORD=""
    local TXT_FILE="/etc/opendkim/keys/$DOMAIN/$SELECTOR.txt"
    if [ -f "$TXT_FILE" ]; then
        DKIM_RECORD=$(extract_dkim_record "$TXT_FILE")
    fi
    # Auto-discover if expected path failed
    if [ -z "$DKIM_RECORD" ]; then
        local found_txt
        found_txt=$(find /etc/opendkim/keys -name "$SELECTOR.txt" -type f 2>/dev/null | head -1)
        if [ -n "$found_txt" ]; then
            log_info "Found DKIM file at: $found_txt"
            DKIM_RECORD=$(extract_dkim_record "$found_txt")
        fi
    fi
    if [ -z "$DKIM_RECORD" ] && [ -f /usr/local/mailx_dkim_record.txt ]; then
        DKIM_RECORD=$(cat /usr/local/mailx_dkim_record.txt)
    fi
    if [ -z "$DKIM_RECORD" ] && [ -f /tmp/dkim_txt_record.txt ]; then
        DKIM_RECORD=$(cat /tmp/dkim_txt_record.txt)
    fi

    # Persist for future use if we found it
    if [ -n "$DKIM_RECORD" ] && [ ! -f /usr/local/mailx_dkim_record.txt ]; then
        echo "$DKIM_RECORD" > /usr/local/mailx_dkim_record.txt
    fi

    if [ -z "$DKIM_RECORD" ]; then
        log_error "No DKIM record found."
        log_error "Checked: $TXT_FILE"
        log_error "Checked: /usr/local/mailx_dkim_record.txt"
        log_error "Checked: /tmp/dkim_txt_record.txt"
        log_info "Listing /etc/opendkim/keys/ contents:"
        ls -laR /etc/opendkim/keys/ 2>/dev/null || echo "  (directory not found)"
        return 1
    fi

    local server_ip=$(curl -s ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')

    echo "1. DKIM Record:"
    echo "   Type:  TXT"
    echo "   Host:  $SELECTOR._domainkey.$DOMAIN"
    echo "   Value: \"$DKIM_RECORD\""
    echo
    echo "2. SPF Record:"
    echo "   Type:  TXT"
    echo "   Host:  $DOMAIN"
    echo "   Value: \"v=spf1 mx a ip4:$server_ip ~all\""
    echo
    echo "3. DMARC Record:"
    echo "   Type:  TXT"
    echo "   Host:  _dmarc.$DOMAIN"
    echo "   Value: \"v=DMARC1; p=none; rua=mailto:admin@$DOMAIN\""
    echo
    echo "4. MX Record:"
    echo "   Type:     MX"
    echo "   Host:     $DOMAIN"
    echo "   Value:    mail.$DOMAIN"
    echo "   Priority: 10"
    echo
    echo "5. A Records:"
    echo "   $DOMAIN       -> $server_ip"
    echo "   mail.$DOMAIN  -> $server_ip"
    echo
}

resend_dkim_record() {
    local recipient=$1
    local DOMAIN=""
    if [ -f /usr/local/roundcube_mail_domain.txt ]; then
        DOMAIN=$(cat /usr/local/roundcube_mail_domain.txt | tr -d '[:space:]')
    fi
    local SELECTOR="default"

    if [ -z "$DOMAIN" ]; then
        log_error "No domain configured. Run the installer first."
        return 1
    fi

    if [ -z "$recipient" ]; then
        log_error "No recipient email provided."
        return 1
    fi

    # Try multiple locations: generated file, persistent cache, temp cache
    local DKIM_RECORD=""
    local TXT_FILE="/etc/opendkim/keys/$DOMAIN/$SELECTOR.txt"
    if [ -f "$TXT_FILE" ]; then
        DKIM_RECORD=$(extract_dkim_record "$TXT_FILE")
    fi
    # Auto-discover if expected path failed
    if [ -z "$DKIM_RECORD" ]; then
        local found_txt
        found_txt=$(find /etc/opendkim/keys -name "$SELECTOR.txt" -type f 2>/dev/null | head -1)
        if [ -n "$found_txt" ]; then
            log_info "Found DKIM file at: $found_txt"
            DKIM_RECORD=$(extract_dkim_record "$found_txt")
        fi
    fi
    if [ -z "$DKIM_RECORD" ] && [ -f /usr/local/mailx_dkim_record.txt ]; then
        DKIM_RECORD=$(cat /usr/local/mailx_dkim_record.txt)
    fi
    if [ -z "$DKIM_RECORD" ] && [ -f /tmp/dkim_txt_record.txt ]; then
        DKIM_RECORD=$(cat /tmp/dkim_txt_record.txt)
    fi

    # Persist for future use if we found it
    if [ -n "$DKIM_RECORD" ] && [ ! -f /usr/local/mailx_dkim_record.txt ]; then
        echo "$DKIM_RECORD" > /usr/local/mailx_dkim_record.txt
    fi

    if [ -z "$DKIM_RECORD" ]; then
        log_error "No DKIM record found."
        log_error "Checked: $TXT_FILE"
        log_error "Checked: /usr/local/mailx_dkim_record.txt"
        log_error "Checked: /tmp/dkim_txt_record.txt"
        log_info "Listing /etc/opendkim/keys/ contents:"
        ls -laR /etc/opendkim/keys/ 2>/dev/null || echo "  (directory not found)"
        return 1
    fi

    local server_ip=$(curl -s ifconfig.me 2>/dev/null || hostname -I | awk '{print $1}')
    local dkim_host="$SELECTOR._domainkey.$DOMAIN"

    local body="===========================================
DKIM & DNS Records for $DOMAIN
===========================================

1. DKIM Record (Required for email authentication):
   Type: TXT
   Host: $dkim_host
   Value: \"$DKIM_RECORD\"

2. SPF Record:
   Type: TXT
   Host: $DOMAIN
   Value: \"v=spf1 mx a ip4:$server_ip ~all\"

3. DMARC Record:
   Type: TXT
   Host: _dmarc.$DOMAIN
   Value: \"v=DMARC1; p=none; rua=mailto:admin@$DOMAIN\"

4. MX Record:
   Type: MX
   Host: $DOMAIN
   Value: mail.$DOMAIN
   Priority: 10

5. A Records:
   $DOMAIN       -> $server_ip
   mail.$DOMAIN  -> $server_ip

VERIFICATION:
   dig TXT $dkim_host
   dig TXT $DOMAIN | grep SPF
   dig MX $DOMAIN

==========================================="

    echo -e "$body" | mail -s "MailX DNS Records for $DOMAIN" -a "From: admin@$DOMAIN" "$recipient" 2>/dev/null
    if [ $? -eq 0 ]; then
        log_info "DKIM & DNS records sent to $recipient"
    else
        log_error "Failed to send email. Displaying records on screen instead:"
        echo -e "$body"
    fi
}


# Network diagnostics and fix
fix_network_for_ppa() {
    log_info "Checking network connectivity to PPA..."
    
    # Test connectivity
    if ! curl -s --connect-timeout 5 https://ppa.launchpadcontent.net > /dev/null; then
        log_warning "Cannot reach PPA server, checking DNS..."
        
        # Try different DNS servers
        echo "nameserver 8.8.8.8" > /etc/resolv.conf
        echo "nameserver 1.1.1.1" >> /etc/resolv.conf
        
        # Flush DNS cache
        systemd-resolve --flush-caches 2>/dev/null || true
        
        # Retry connection
        sleep 2
        if ! curl -s --connect-timeout 5 https://ppa.launchpadcontent.net > /dev/null; then
            log_warning "Still cannot reach PPA. Will proceed with fallback..."
            return 1
        fi
    fi
    
    return 0
}


# ============================================================================
# Main Installation Function with Checkpoints
# ============================================================================

install_roundcube() {
    local EMAIL_DOMAIN=$1
    local HOSTNAME=$2
    local ADMIN_MAILX_EMAIL=$3

    # Stage 1: System Preparation
    if ! is_stage_completed "system_preparation"; then
        log_info "=== Stage 1: System Preparation ==="

        echo "$HOSTNAME" > /etc/hostname
        sed -i "s/127.0.0.1.*/127.0.0.1 localhost $HOSTNAME/" /etc/hosts
        hostnamectl set-hostname $HOSTNAME 2>/dev/null || true

        if [[ "$HOSTNAME" =~ ^[a-zA-Z0-9.-]+\.[a-zA-Z]{2,}$ ]]; then
            echo "$HOSTNAME" | tee /etc/mailname > /dev/null
        fi

        apt-get -qq update > /dev/null

        mark_stage_complete "system_preparation"
    fi

    # Stage 2: MySQL Installation
    if ! is_stage_completed "mysql_installation"; then
        log_info "=== Stage 2: MySQL Installation ==="

        local MYSQL_ROOT_PASSWORD=$(retrieve_file_data /usr/local/mysql_root_pwd.txt)
        local ROUNDCUBE_DB_PASSWORD=$(retrieve_file_data /usr/local/roundcube_db_pwd.txt)
        local ROUNDCUBE_DB_USER="roundcube"
        local ROUNDCUBE_DB_NAME="roundcubemail"

        export DEBIAN_FRONTEND=noninteractive
        debconf-set-selections <<< "mysql-server mysql-server/root_password password $MYSQL_ROOT_PASSWORD"
        debconf-set-selections <<< "mysql-server mysql-server/root_password_again password $MYSQL_ROOT_PASSWORD"
        apt-get -qq install -y mysql-server > /dev/null

        cat <<EOF > ~/.my.cnf
[client]
user=root
password=$MYSQL_ROOT_PASSWORD
EOF
        chmod 600 ~/.my.cnf

        mysql -e "CREATE DATABASE IF NOT EXISTS $ROUNDCUBE_DB_NAME;" 2>/dev/null
        mysql -e "CREATE USER IF NOT EXISTS '$ROUNDCUBE_DB_USER'@'localhost' IDENTIFIED BY '$ROUNDCUBE_DB_PASSWORD';" 2>/dev/null
        mysql -e "GRANT ALL PRIVILEGES ON $ROUNDCUBE_DB_NAME.* TO '$ROUNDCUBE_DB_USER'@'localhost';" 2>/dev/null
        mysql -e "FLUSH PRIVILEGES;" 2>/dev/null

        mark_stage_complete "mysql_installation"
    fi

    # Stage 3: PHP and Basic Packages
    if ! is_stage_completed "php_installation"; then
        log_info "=== Stage 3: PHP and Basic Packages Installation ==="
        fix_network_for_ppa

        apt_install software-properties-common

        LC_ALL=C.UTF-8 add-apt-repository ppa:ondrej/php -y > /dev/null 2>&1
        apt-get -qq update > /dev/null

        log_info "Installing PHP 8.1..."
        apt_install php8.1 php8.1-fpm php8.1-cli php8.1-common php8.1-curl php8.1-mysql php8.1-xml php8.1-mbstring php8.1-zip php8.1-intl php8.1-pspell

        log_info "Installing PHP 8.3..."
        apt_install php8.3 php8.3-fpm php8.3-cli php8.3-common php8.3-curl php8.3-mysql php8.3-xml php8.3-mbstring php8.3-zip php8.3-intl php8.3-pspell

        log_info "Installing PHP 8.4..."
        apt_install php8.4 php8.4-fpm php8.4-cli php8.4-common php8.4-curl php8.4-mysql php8.4-xml php8.4-mbstring php8.4-zip php8.4-intl php8.4-pspell

        log_info "Installing PHP 5.6..."
        apt_install php5.6 php5.6-fpm php5.6-cli php5.6-common php5.6-curl php5.6-mysql php5.6-xml php5.6-mbstring php5.6-zip php5.6-intl php5.6-pspell

        mark_stage_complete "php_installation"
    fi

    # Stage 4: Mail Server Installation
    if ! is_stage_completed "mail_server_installation"; then
        log_info "=== Stage 4: Mail Server Installation ==="

        apt_install postfix mailutils dovecot-core dovecot-imapd dovecot-pop3d dovecot-mysql

        configure_dovecot_quota
        configure_dovecot_sasl

        systemctl restart dovecot postfix 2>/dev/null || true

        verify_postfix_dovecot_connection
        test_sasl_authentication

        mark_stage_complete "mail_server_installation"
    fi

    # Stage 5: Apache Installation
    if ! is_stage_completed "apache_installation"; then
        log_info "=== Stage 5: Apache Installation ==="

        apt_install apache2 libapache2-mod-fcgid

        if [ ! -d "/etc/apache2" ]; then
            apt-get install --reinstall -y apache2
        fi

        if [ -f "/etc/apache2/ports.conf" ]; then
            cp /etc/apache2/ports.conf /etc/apache2/ports.conf.bak
            retry_command wget -qO /etc/apache2/ports.conf https://raw.githubusercontent.com/gtmylab/mailx/main/apache2/ports.conf
        fi

        a2enmod actions fcgid alias proxy_fcgi ssl headers rewrite > /dev/null 2>&1

        mkdir -p /etc/php/8.1/fpm/pool.d /etc/php/8.3/fpm/pool.d /etc/php/8.4/fpm/pool.d /etc/php/5.6/fpm/pool.d

        retry_command wget -qO /etc/php/8.1/fpm/pool.d/www.conf https://raw.githubusercontent.com/gtmylab/mailx/main/php8/www.conf
        retry_command wget -qO /etc/php/8.3/fpm/pool.d/www.conf https://raw.githubusercontent.com/gtmylab/mailx/main/php8/3/www.conf
        retry_command wget -qO /etc/php/8.4/fpm/pool.d/www.conf https://raw.githubusercontent.com/gtmylab/mailx/main/php8/4/www.conf
        retry_command wget -qO /etc/php/5.6/fpm/pool.d/www.conf https://raw.githubusercontent.com/gtmylab/mailx/main/php5/www.conf

        update_php_ini "post_max_size" "50M" "/etc/php/5.6/fpm/php.ini"
        update_php_ini "upload_max_filesize" "50M" "/etc/php/5.6/fpm/php.ini"

        systemctl restart php8.1-fpm php8.3-fpm php8.4-fpm php5.6-fpm 2>/dev/null || true

        mark_stage_complete "apache_installation"
    fi

    # Stage 6: Apache Virtual Hosts
    if ! is_stage_completed "apache_vhosts"; then
        log_info "=== Stage 6: Apache Virtual Hosts Configuration ==="

        mkdir -p /var/www/html/{roundcube,mailx,adminportal,phpmyadmin,.well-known/acme-challenge}
        chown -R www-data:www-data /var/www/html

        cat <<EOF > /etc/apache2/sites-available/roundcube.conf
<VirtualHost *:8080>
    ServerName $HOSTNAME
    DocumentRoot /var/www/html/roundcube
    <Directory /var/www/html/roundcube/>
        Options +FollowSymlinks
        AllowOverride All
        <IfModule mod_dir.c>
            DirectoryIndex index.php
        </IfModule>
    </Directory>
    <FilesMatch \.php\$>
        SetHandler "proxy:unix:/run/php/php8.1-fpm.sock|fcgi://localhost"
    </FilesMatch>
    ErrorLog \${APACHE_LOG_DIR}/roundcube_error.log
    CustomLog \${APACHE_LOG_DIR}/roundcube_access.log combined
</VirtualHost>
EOF

        cat <<EOF > /etc/apache2/sites-available/adminportal.conf
<VirtualHost *:9090>
    ServerName $HOSTNAME
    DocumentRoot /var/www/html/adminportal
    <Directory /var/www/html/adminportal/>
        Options +FollowSymLinks -Indexes
        AllowOverride All
        Require all granted
        <IfModule mod_dir.c>
            DirectoryIndex index.php
        </IfModule>
    </Directory>
    <FilesMatch \.php\$>
        SetHandler "proxy:unix:/run/php/php8.4-fpm.sock|fcgi://localhost"
    </FilesMatch>
    ErrorLog \${APACHE_LOG_DIR}/adminportal_error.log
    CustomLog \${APACHE_LOG_DIR}/adminportal_access.log combined
</VirtualHost>
EOF

        cat <<EOF > /etc/apache2/sites-available/mailx.conf
<VirtualHost *:8081>
    ServerName $EMAIL_DOMAIN
    DocumentRoot /var/www/html/mailx
    <Directory /var/www/html/mailx/>
        Options +FollowSymlinks
        AllowOverride All
        <IfModule mod_dir.c>
            DirectoryIndex index.php
        </IfModule>
    </Directory>
    <FilesMatch \.php\$>
        SetHandler "proxy:unix:/run/php/php5.6-fpm.sock|fcgi://localhost"
    </FilesMatch>
    ErrorLog \${APACHE_LOG_DIR}/mailx_error.log
    CustomLog \${APACHE_LOG_DIR}/mailx_access.log combined
</VirtualHost>
EOF

        cat <<EOF > /etc/apache2/sites-available/phpmyadmin.conf
<VirtualHost *:8082>
    ServerName $HOSTNAME
    DocumentRoot /var/www/html/phpmyadmin
    <Directory /var/www/html/phpmyadmin/>
        Options +FollowSymlinks
        AllowOverride All
        <IfModule mod_dir.c>
            DirectoryIndex index.php
        </IfModule>
    </Directory>
    <FilesMatch \.php\$>
        SetHandler "proxy:unix:/run/php/php8.1-fpm.sock|fcgi://localhost"
    </FilesMatch>
    ErrorLog \${APACHE_LOG_DIR}/phpmyadmin_error.log
    CustomLog \${APACHE_LOG_DIR}/phpmyadmin_access.log combined
</VirtualHost>
EOF

        a2ensite roundcube.conf adminportal.conf mailx.conf phpmyadmin.conf > /dev/null 2>&1

        mark_stage_complete "apache_vhosts"
    fi

    # Stage 7: PHPMyAdmin Installation
    if ! is_stage_completed "phpmyadmin_installation"; then
        log_info "=== Stage 7: PHPMyAdmin Installation ==="

        setup_phpmyadmin

        mark_stage_complete "phpmyadmin_installation"
    fi

    # Stage 8: SSL Certificate Installation
    if ! is_stage_completed "ssl_installation"; then
        log_info "=== Stage 8: SSL Certificate Installation ==="

        if manage_ssl_certificates install "$HOSTNAME"; then
            mark_stage_complete "ssl_installation"
        else
            log_warning "SSL certificate installation failed. Will retry on next run."
        fi
    fi

    # Stage 9: Roundcube Installation
    if ! is_stage_completed "roundcube_installation"; then
        if execute_stage "roundcube_installation" install_roundcube_application "$EMAIL_DOMAIN" "$HOSTNAME"; then
            log_info "Roundcube installed successfully"
        else
            log_warning "Roundcube installation had issues, attempting verification..."
            verify_roundcube_installation "$EMAIL_DOMAIN"
        fi
    fi

    # Stage 10: Postfix Configuration
    if ! is_stage_completed "postfix_configuration"; then
        log_info "=== Stage 10: Postfix Configuration ==="

        update_postfix_config "$EMAIL_DOMAIN" "$HOSTNAME"
        update_postfix_virtual "$EMAIL_DOMAIN" "admin"
        setup_postfix_header_checks "$HOSTNAME"

        # Validate configuration
        if postfix check 2>/dev/null; then
            log_info "Postfix configuration validated successfully"
        else
            log_warning "Postfix configuration check had warnings"
        fi

        restart_service postfix

        repair_postfix_config "$EMAIL_DOMAIN" "$HOSTNAME"

        mark_stage_complete "postfix_configuration"
    fi

    # Stage 11: DKIM Generation and Configuration
    if ! is_stage_completed "dkim_generation"; then
        log_info "=== Stage 11: DKIM Generation and Configuration ==="

        # Generate DKIM key (installs opendkim if needed, creates user)
        if generate_dkim_key "$EMAIL_DOMAIN"; then
            log_info "DKIM key generated/verified"

            # Configure and start OpenDKIM service, integrate with Postfix
            if configure_opendkim "$EMAIL_DOMAIN"; then
                log_info "OpenDKIM service configured successfully"

                # Verify the full chain is working
                verify_dkim "$EMAIL_DOMAIN"

                mark_stage_complete "dkim_generation"
            else
                log_warning "OpenDKIM service configuration had issues"
                # Key exists, mark complete so we don't re-generate on retry
                mark_stage_complete "dkim_generation"
            fi
        else
            log_error "DKIM key generation failed"
            # Don't mark as complete — will retry next run
        fi
    fi

    # Stage 12: Additional Files
    if ! is_stage_completed "additional_files"; then
        log_info "=== Stage 12: Additional Files ==="

        mkdir -p /var/www/html/mailx
        retry_command wget -qO /var/www/html/mailx/index.php https://raw.githubusercontent.com/gtmylab/mailx/main/mailer.php
        chown -R www-data:www-data /var/www/html/mailx

        mkdir -p /var/www/html/adminportal
        chown -R www-data:www-data /var/www/html/adminportal

        mark_stage_complete "additional_files"
    fi

    # Final: Restart Services
    log_info "=== Final: Restarting Services ==="
    systemctl restart apache2 postfix dovecot 2>/dev/null || true
    systemctl restart opendkim 2>/dev/null || true

    # Send notification email with all details
    if ! is_stage_completed "notification_sent"; then
        local DKIM_RECORD=""
        if [ -f "/tmp/dkim_txt_record.txt" ]; then
            DKIM_RECORD=$(cat /tmp/dkim_txt_record.txt)
        fi

        send_notification_email "$ADMIN_MAILX_EMAIL" "http://$HOSTNAME:8080" "roundcube" \
            "$(retrieve_file_data /usr/local/roundcube_db_pwd.txt)" \
            "http://$EMAIL_DOMAIN:8081" "$DKIM_RECORD" "default" "http://$HOSTNAME:8082"

        mark_stage_complete "notification_sent"
    fi

    log_info "MailX Installation Completed Successfully!"
}

