    if [ -f "/etc/opendkim/keys/$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null)/default.private" ] 2>/dev/null; then
        echo "  ✓ DKIM key generated"
    else
        echo "  ✗ DKIM key not generated"
    fi
    if systemctl is-active --quiet opendkim 2>/dev/null; then
        echo "  ✓ DKIM signing active"
