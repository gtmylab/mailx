uninstall_all() {
    echo ""
    echo "=============================================="
    echo "  MailX Complete Uninstaller"
    echo "=============================================="
    echo ""
    echo "This will COMPLETELY remove all MailX components:"
    echo "  - Postfix, Dovecot, OpenDKIM (mail services)"
    echo "  - MySQL Server and all databases"
    echo "  - Apache2 and all virtual hosts"
    echo "  - PHP 5.6, 8.1, 8.3, 8.4 and all extensions"
    echo "  - Roundcube, PHPMyAdmin, MailX web files"
    echo "  - SSL certificates (Let's Encrypt)"
    echo "  - All created users (vmail, opendkim)"
    echo "  - All config files, logs, and state data"
    echo "  - ondrej/php PPA"
    echo ""
    echo "WARNING: This action is IRREVERSIBLE!"
    echo ""
    read -p "Type 'UNINSTALL' to confirm complete removal: " CONFIRM
    if [[ "$CONFIRM" != "UNINSTALL" ]]; then
        log_info "Uninstall cancelled."
        return 0
    fi

    log_info "Starting complete MailX uninstallation..."

    # ── Step 1: Stop all services ──
    log_info "Stopping all services..."
    local services="postfix dovecot apache2 mysql opendkim php8.1-fpm php8.3-fpm php8.4-fpm php5.6-fpm certbot.timer"
    for svc in $services; do
        systemctl stop "$svc" 2>/dev/null || true
        systemctl disable "$svc" 2>/dev/null || true
    done

    # ── Step 2: Drop MySQL databases and users ──
    log_info "Removing MySQL databases and users..."
    if systemctl start mysql 2>/dev/null; then
        mysql -e "DROP DATABASE IF EXISTS roundcubemail;" 2>/dev/null || true
        mysql -e "DROP USER IF EXISTS 'roundcube'@'localhost';" 2>/dev/null || true
        mysql -e "FLUSH PRIVILEGES;" 2>/dev/null || true
        systemctl stop mysql 2>/dev/null || true
    fi

    # ── Step 3: Remove the custom OpenDKIM systemd unit ──
    log_info "Removing custom systemd units..."
    rm -f /etc/systemd/system/opendkim.service
    systemctl daemon-reload 2>/dev/null || true

    # ── Step 4: Remove crontab entries added by installer ──
    log_info "Removing crontab entries..."
    (crontab -l 2>/dev/null | grep -v "ssl_renewal.sh") | crontab - 2>/dev/null || true

    # ── Step 5: Disable Apache sites and modules before purge ──
    log_info "Disabling Apache sites..."
    for site in roundcube adminportal mailx phpmyadmin 000-default default-ssl; do
        a2dissite "$site" 2>/dev/null || true
    done

    # ── Step 6: Purge all installed packages ──
    log_info "Purging installed packages..."
    export DEBIAN_FRONTEND=noninteractive

    apt-get -y remove --purge \
        postfix postfix-mysql mailutils \
        dovecot-core dovecot-imapd dovecot-pop3d dovecot-mysql dovecot-sieve dovecot-managesieved \
        sasl2-bin \
        opendkim opendkim-tools \
        mysql-server mysql-client mysql-common \
        apache2 libapache2-mod-fcgid \
        certbot python3-certbot-apache \
        2>/dev/null || true

    # Purge all PHP packages (all versions)
    local php_pkgs
    php_pkgs=$(dpkg -l 2>/dev/null | awk '/^ii.*php/ {print $2}')
    if [ -n "$php_pkgs" ]; then
        apt-get -y remove --purge $php_pkgs 2>/dev/null || true
    fi

    # ── Step 7: Remove ondrej/php PPA ──
    log_info "Removing ondrej/php PPA..."
    if command -v add-apt-repository &>/dev/null; then
        add-apt-repository --remove ppa:ondrej/php -y 2>/dev/null || true
    fi
    rm -f /etc/apt/sources.list.d/ondrej-*.list /etc/apt/sources.list.d/ondrej-*.list.save 2>/dev/null || true

    # ── Step 8: Remove all configuration directories ──
    log_info "Removing configuration directories..."
    rm -rf /etc/postfix
    rm -rf /etc/dovecot
    rm -rf /etc/opendkim /etc/opendkim.conf
    rm -rf /etc/apache2
    rm -rf /etc/mysql
    rm -rf /etc/php

    # ── Step 9: Remove all data directories ──
    log_info "Removing data directories..."
    rm -rf /var/lib/mysql
    rm -rf /var/lib/dovecot
    rm -rf /var/lib/opendkim
    rm -rf /var/lib/postfix
    rm -rf /var/spool/postfix
    rm -rf /var/mail/vmail
    rm -rf /var/run/opendkim

    # ── Step 10: Remove web directories ──
    log_info "Removing web directories..."
    rm -rf /var/www/html/roundcube
    rm -rf /var/www/html/phpmyadmin
    rm -rf /var/www/html/mailx
    rm -rf /var/www/html/adminportal
    rm -rf /var/www/html/.well-known

    # ── Step 11: Remove log files ──
    log_info "Removing log files..."
    rm -rf /var/log/mailx
    rm -rf /var/log/mysql*
    rm -rf /var/log/mail.*
    rm -rf /var/log/dovecot*
    rm -rf /var/log/opendkim*

    # ── Step 12: Remove MailX persistent files ──
    log_info "Removing MailX data files..."
    rm -f /usr/local/mysql_root_pwd.txt
    rm -f /usr/local/roundcube_db_pwd.txt
    rm -f /usr/local/roundcube_mail_domain.txt
    rm -f /usr/local/mailx_dkim_record.txt
    rm -f /usr/local/bin/ssl_renewal.sh
    rm -f /tmp/dkim_txt_record.txt
    rm -f /tmp/mailx_dns_records.txt
    rm -f ~/.my.cnf

    # ── Step 13: Remove Let's Encrypt SSL data ──
    log_info "Removing Let's Encrypt data..."
    rm -rf /etc/letsencrypt
    rm -rf /var/lib/letsencrypt
    rm -rf /var/log/letsencrypt

    # ── Step 14: Remove system users and groups ──
    log_info "Removing system users and groups..."
    userdel -r vmail 2>/dev/null || true
    groupdel vmail 2>/dev/null || true
    userdel opendkim 2>/dev/null || true
    groupdel opendkim 2>/dev/null || true
    userdel mysql 2>/dev/null || true
    groupdel mysql 2>/dev/null || true

    # ── Step 15: Remove state directory ──
    log_info "Removing state tracking..."
    rm -rf "$STATE_DIR"

    # ── Step 16: Clean up apt cache and orphaned dependencies ──
    log_info "Cleaning up package cache..."
    apt-get -y autoremove --purge 2>/dev/null || true
    apt-get -y autoclean 2>/dev/null || true
    apt-get -y clean 2>/dev/null || true
    apt-get -qq update > /dev/null 2>&1 || true

    # ── Step 17: Restore hostname to default ──
    log_info "Resetting hostname..."
    echo "localhost" > /etc/hostname
    hostnamectl set-hostname "localhost" 2>/dev/null || true
    sed -i 's/^127\.0\.0\.1.*/127.0.0.1 localhost/' /etc/hosts 2>/dev/null || true
    rm -f /etc/mailname

    echo ""
    echo "=============================================="
    log_info "MailX has been completely uninstalled."
    echo "=============================================="
    echo ""
    echo "The following have been removed:"
    echo "  ✓ Mail services (Postfix, Dovecot, OpenDKIM)"
    echo "  ✓ Database (MySQL Server + all data)"
    echo "  ✓ Web server (Apache2 + all vhosts)"
    echo "  ✓ PHP (all versions + extensions)"
    echo "  ✓ Webmail (Roundcube, PHPMyAdmin)"
    echo "  ✓ SSL certificates (Let's Encrypt)"
    echo "  ✓ System users (vmail, opendkim, mysql)"
    echo "  ✓ All logs, configs, and state files"
    echo "  ✓ Crontab entries and PPA"
    echo ""
    echo "System has been returned to its original state."
    echo "A reboot is recommended: reboot"
    echo ""
}

change_domain_hostname() {
    local old_domain=$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null || echo "")
    local old_hostname=$(hostname)

    if [ -z "$old_domain" ]; then
        log_error "No existing domain found"
        return 1
    fi

    echo "Current Domain: $old_domain"
    echo "Current Hostname: $old_hostname"
    echo

    read -p "Enter new email domain (e.g., example.com): " new_domain
    read -p "Enter new hostname (e.g., mail.example.com): " new_hostname

    if [[ -z "$new_domain" || -z "$new_hostname" ]]; then
        log_error "Both domain and hostname are required."
        return 1
    fi

    echo "$new_hostname" > /etc/hostname
    hostnamectl set-hostname "$new_hostname"
    sed -i "s/$old_hostname/$new_hostname/g" /etc/hosts

    echo "$new_hostname" > /etc/mailname
    echo "$new_domain" > /usr/local/roundcube_mail_domain.txt

    sed -i "s/$old_domain/$new_domain/g" /etc/postfix/main.cf 2>/dev/null || true
    sed -i "s/$old_hostname/$new_hostname/g" /etc/postfix/main.cf 2>/dev/null || true

    if [ -f "/etc/postfix/header_checks" ]; then
        sed -i "s/$old_hostname/$new_hostname/g" /etc/postfix/header_checks
    fi

    if [ -f "/var/www/html/roundcube/config/config.inc.php" ]; then
        sed -i "s/$old_domain/$new_domain/g" /var/www/html/roundcube/config/config.inc.php
        sed -i "s/mail_domain'] = .*/mail_domain'] = '$new_domain';/" /var/www/html/roundcube/config/config.inc.php
    fi

    for config_file in /etc/apache2/sites-available/*.conf; do
        [ -f "$config_file" ] && sed -i "s/$old_domain/$new_domain/g" "$config_file" 2>/dev/null || true
        [ -f "$config_file" ] && sed -i "s/$old_hostname/$new_hostname/g" "$config_file" 2>/dev/null || true
    done

    # Re-generate DKIM for new domain and reconfigure OpenDKIM
    generate_dkim_key "$new_domain"
    configure_opendkim "$new_domain"

    restart_service postfix
    restart_service dovecot
    restart_service apache2

    manage_ssl_certificates change "$new_domain"

    log_info "Domain changed successfully to $new_domain with hostname $new_hostname"
}

repair_postfix_config() {
    echo ""
    echo "=============================================="
    echo "  Postfix Configuration Repair"
    echo "=============================================="
    echo ""
    echo "This will re-download the known-good main.cf and master.cf"
    echo "from GitHub and re-apply your domain settings."
    echo ""

    local domain=$(cat /usr/local/roundcube_mail_domain.txt 2>/dev/null | tr -d '[:space:]')
    local host=$(hostname)

    if [ -z "$domain" ]; then
        read -p "Enter your email domain (e.g., example.com): " domain
    fi
    if [ -z "$host" ] || [ "$host" = "localhost" ]; then
        read -p "Enter your hostname (e.g., mail.example.com): " host
    fi

    echo "Domain:   $domain"
    echo "Hostname: $host"
  #  read -p "Proceed with repair? (y/n): " confirm
   # if [[ "$confirm" != "y" ]]; then
  #      log_info "Repair cancelled."
   #     return 0
   # fi

    local config_dir="/etc/postfix"

    # Backup current configs
    local timestamp=$(date +%Y%m%d_%H%M%S)
    cp "$config_dir/main.cf" "$config_dir/main.cf.pre-repair_${timestamp}" 2>/dev/null || true
    cp "$config_dir/master.cf" "$config_dir/master.cf.pre-repair_${timestamp}" 2>/dev/null || true
    log_info "Backed up current configs with timestamp $timestamp"

    # Download fresh main.cf
    log_info "Downloading main.cf from GitHub..."
    if retry_command "wget -q --timeout=30 --tries=3 -O ${config_dir}/main.cf.tmp https://raw.githubusercontent.com/gtmylab/mailx/main/postfix_main.cf"; then
        if [[ -s "${config_dir}/main.cf.tmp" ]]; then
            mv "${config_dir}/main.cf.tmp" "${config_dir}/main.cf"
            log_info "main.cf downloaded successfully"
        else
            rm -f "${config_dir}/main.cf.tmp"
            log_error "Downloaded main.cf was empty"
            return 1
        fi
    else
        rm -f "${config_dir}/main.cf.tmp"
        log_error "Failed to download main.cf"
        return 1
    fi

    # Download fresh master.cf
    log_info "Downloading master.cf from GitHub..."
    if retry_command "wget -q --timeout=30 --tries=3 -O ${config_dir}/master.cf.tmp https://raw.githubusercontent.com/gtmylab/mailx/main/postfix_master.cf"; then
        if [[ -s "${config_dir}/master.cf.tmp" ]]; then
            mv "${config_dir}/master.cf.tmp" "${config_dir}/master.cf"
            log_info "master.cf downloaded successfully"
        else
            rm -f "${config_dir}/master.cf.tmp"
            log_error "Downloaded master.cf was empty"
            return 1
        fi
    else
        rm -f "${config_dir}/master.cf.tmp"
        log_error "Failed to download master.cf"
        return 1
    fi

    # Replace placeholders
    sed -i "s/{EMAIL_DOMAIN}/$domain/g; s/{HOSTNAME}/$host/g" "${config_dir}/main.cf" 2>/dev/null || true
    sed -i "s/{EMAIL_DOMAIN}/$domain/g; s/{HOSTNAME}/$host/g" "${config_dir}/master.cf" 2>/dev/null || true
    log_info "Placeholders replaced with domain=$domain hostname=$host"

    # Re-create access files
    echo "$host OK" > "$config_dir/helo_access"
    echo ".$domain OK" >> "$config_dir/helo_access"
    postmap "$config_dir/helo_access" 2>/dev/null || true

    echo "$domain OK" > "$config_dir/virtual_domains"
    postmap "$config_dir/virtual_domains" 2>/dev/null || true

    # Re-create virtual map if missing
    if [ ! -f "$config_dir/virtual" ]; then
        touch "$config_dir/virtual"
        postmap "$config_dir/virtual" 2>/dev/null || true
    fi

    # Re-apply header checks
    setup_postfix_header_checks "$host"

    # Re-apply DKIM milter settings if OpenDKIM is configured
    if [ -S "/var/spool/postfix/opendkim/opendkim.sock" ] || systemctl is-active --quiet opendkim 2>/dev/null; then
        postconf -e "milter_default_action = accept"
        postconf -e "milter_protocol = 2"
        postconf -e "smtpd_milters = unix:opendkim/opendkim.sock"
        postconf -e "non_smtpd_milters = unix:opendkim/opendkim.sock"
        log_info "DKIM milter settings re-applied"
    fi

    # Re-apply SSL cert paths if they exist
    local cert_path="/etc/letsencrypt/live/$domain"
    if [ -d "$cert_path" ]; then
        postconf -e "smtpd_tls_cert_file=$cert_path/fullchain.pem"
        postconf -e "smtpd_tls_key_file=$cert_path/privkey.pem"
        log_info "SSL certificate paths re-applied"
    fi

    # Validate
    if postfix check 2>/dev/null; then
        log_info "Postfix configuration validated successfully"
    else
        log_warning "Postfix configuration check had warnings"
    fi

    restart_service postfix

    echo ""
    echo "=============================================="
    log_info "Postfix configuration repaired successfully!"
    echo "=============================================="
    echo ""
    echo "Listening ports:"
    grep -E '^(smtp|submission|smtps|[0-9]+)\s+inet' /etc/postfix/master.cf 2>/dev/null | awk '{print "  " $1}' || true
    echo ""
    echo "Pre-repair configs backed up as:"
    echo "  main.cf.pre-repair_${timestamp}"
    echo "  master.cf.pre-repair_${timestamp}"
    echo ""
}

set_postfix_custom_port() {
    echo ""
    echo "Current Postfix listening ports:"
    grep -E '^(smtp|submission|smtps|[0-9]+)\s+inet' /etc/postfix/master.cf 2>/dev/null | awk '{print "  " $1}' || echo "  (unable to read master.cf)"
    echo ""

    read -p "Enter new SMTP port number to ADD (e.g., 2525, 2580): " new_port

    if [[ ! "$new_port" =~ ^[0-9]+$ ]] || [ "$new_port" -lt 1 ] || [ "$new_port" -gt 65535 ]; then
        log_error "Invalid port number"
        return 1
    fi

    # Check if this port is already configured
    if grep -qE "^${new_port}\s+inet" /etc/postfix/master.cf 2>/dev/null; then
        log_warning "Port $new_port is already configured in master.cf"
        read -p "Replace existing entry? (y/n): " replace_confirm
        if [[ "$replace_confirm" != "y" ]]; then
            return 0
        fi
        # Remove existing custom port block (port line + following -o lines)
        sed -i "/^${new_port}\s\+inet/,/^[^[:space:]]/{/^${new_port}\s\+inet/d; /^\s\+-o /d}" /etc/postfix/master.cf
    fi

    # Backup before modifying
    cp /etc/postfix/master.cf /etc/postfix/master.cf.bak

    # Re-download the clean master.cf from GitHub to restore any previous damage
    local config_dir="/etc/postfix"
    local domain=$(cat /usr/local/roundcube_mail_domain.txt 2>/dev/null | tr -d '[:space:]')
    local hostname=$(hostname)

    read -p "Re-download clean master.cf from GitHub? (recommended) (y/n): " redownload
    if [[ "$redownload" == "y" ]]; then
        log_info "Downloading clean master.cf from GitHub..."
        if retry_command "wget -q --timeout=30 --tries=3 -O ${config_dir}/master.cf.tmp https://raw.githubusercontent.com/gtmylab/mailx/main/postfix_master.cf"; then
            if [[ -s "${config_dir}/master.cf.tmp" ]]; then
                mv "${config_dir}/master.cf.tmp" "${config_dir}/master.cf"
                # Replace placeholders
                sed -i "s/{EMAIL_DOMAIN}/$domain/g; s/{HOSTNAME}/$hostname/g" "${config_dir}/master.cf" 2>/dev/null || true
                log_info "Clean master.cf restored from GitHub"
            else
                rm -f "${config_dir}/master.cf.tmp"
                log_warning "Downloaded file was empty, keeping existing master.cf"
            fi
        else
            rm -f "${config_dir}/master.cf.tmp"
            log_warning "Download failed, keeping existing master.cf"
        fi
    fi

    # Add the custom port as an ADDITIONAL listener (keeps existing 25, 587, 465)
    log_info "Adding custom SMTP port $new_port..."
    cat <<EOF >> /etc/postfix/master.cf

# Custom SMTP port $new_port
${new_port}      inet  n       -       y       -       -       smtpd
  -o syslog_name=postfix/smtp-${new_port}
  -o smtpd_tls_security_level=may
  -o smtpd_sasl_auth_enable=yes
  -o smtpd_client_restrictions=permit_sasl_authenticated,reject
  -o smtpd_sender_login_maps=hash:/etc/postfix/virtual
  -o smtpd_recipient_restrictions=permit_sasl_authenticated,reject
  -o milter_macro_daemon_name=ORIGINATING
EOF

    # Update Roundcube config if needed
    if [ -f "/var/www/html/roundcube/config/config.inc.php" ]; then
        sed -i "s/\$config\['smtp_port'\] = .*/\$config\['smtp_port'\] = $new_port;/" /var/www/html/roundcube/config/config.inc.php
    fi

    # Open firewall port
    if command -v ufw &>/dev/null; then
        ufw allow "$new_port"/tcp 2>/dev/null || true
    fi

    # Validate and restart
    if postfix check 2>/dev/null; then
        log_info "Postfix configuration validated"
    else
        log_warning "Postfix configuration check had warnings (non-fatal)"
    fi

    restart_service postfix

    echo ""
    echo "Postfix now listening on:"
    grep -E '^(smtp|submission|smtps|[0-9]+)\s+inet' /etc/postfix/master.cf 2>/dev/null | awk '{print "  " $1}' || true
    echo ""
    log_info "Custom SMTP port $new_port added successfully"
}

add_domain() {
    local domain=$1
    local domain_file="/usr/local/roundcube_mail_domain.txt"
    local helo_access_file="/etc/postfix/helo_access"
    local virtual_domains_file="/etc/postfix/virtual_domains"

    if check_string_in_file "$domain_file" "$domain"; then
        log_warning "Domain $domain already exists"
        return 1
    fi

    echo "$domain" >> "$domain_file"

    if [ ! -f "$helo_access_file" ]; then
        touch "$helo_access_file"
        chmod 640 "$helo_access_file"
        chown root:postfix "$helo_access_file"
    fi

    if ! grep -qF ".$domain OK" "$helo_access_file" 2>/dev/null; then
        echo ".$domain OK" >> "$helo_access_file"
        postmap "$helo_access_file" 2>/dev/null || true
    fi

    if [ ! -f "$virtual_domains_file" ]; then
        touch "$virtual_domains_file"
        chmod 640 "$virtual_domains_file"
        chown root:postfix "$virtual_domains_file"
    fi

    if ! grep -qF "$domain OK" "$virtual_domains_file" 2>/dev/null; then
        echo "$domain OK" >> "$virtual_domains_file"
        postmap "$virtual_domains_file" 2>/dev/null || true
    fi

    log_info "Domain $domain added successfully"
}

remove_domain() {
    local domain=$1
    local domain_file="/usr/local/roundcube_mail_domain.txt"
    local helo_access_file="/etc/postfix/helo_access"
    local virtual_domains_file="/etc/postfix/virtual_domains"
    local temp_file=$(mktemp)

    local domain_count=$(wc -l < "$domain_file" | tr -d ' ')
    if [ "$domain_count" -le 1 ]; then
        log_error "Cannot remove the last domain"
        return 1
    fi

    if ! check_string_in_file "$domain_file" "$domain"; then
        log_error "Domain $domain does not exist"
        return 1
    fi

    grep -v "^$domain$" "$domain_file" > "$temp_file"
    mv "$temp_file" "$domain_file"

    if [ -f "$helo_access_file" ]; then
        grep -vF ".$domain OK" "$helo_access_file" > "$temp_file"
        mv "$temp_file" "$helo_access_file"
        postmap "$helo_access_file" 2>/dev/null || true
    fi

    if [ -f "$virtual_domains_file" ]; then
        grep -vF "$domain OK" "$virtual_domains_file" > "$temp_file"
        mv "$temp_file" "$virtual_domains_file"
        postmap "$virtual_domains_file" 2>/dev/null || true
    fi

    log_info "Domain $domain removed successfully"
}

