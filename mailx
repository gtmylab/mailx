# ============================================================================
# Roundcube Installation
# ============================================================================

install_roundcube_application() {
    local EMAIL_DOMAIN=$1
    local HOSTNAME=$2

    log_info "=== Stage 9: Roundcube Installation ==="

    local ROUNDCUBE_DB_PASSWORD=$(retrieve_file_data /usr/local/roundcube_db_pwd.txt)
    local ROUNDCUBE_DB_USER="roundcube"
    local ROUNDCUBE_DB_NAME="roundcubemail"
    local ROUNDCUBE_ADMIN_EMAIL="admin@$EMAIL_DOMAIN"
    local ROUNDCUBE_ADMIN_PASS=$(openssl rand -base64 12)

    local CURRENT_DIR=$(pwd)

    cd /var/www/html || {
        log_error "Failed to change to /var/www/html"
        return 1
    }

    # Clean up existing incomplete installation
    if [ -d "roundcube" ] && [ ! -f "roundcube/config/config.inc.php" ]; then
        log_info "Removing incomplete Roundcube installation..."
        rm -rf roundcube
    fi

    # Check if already installed
    if [ -d "roundcube" ] && [ -f "roundcube/config/config.inc.php" ]; then
        log_info "Roundcube already installed, verifying configuration..."
        if grep -q "db_dsnw" roundcube/config/config.inc.php 2>/dev/null; then
            log_info "Roundcube already properly configured, skipping..."
            cd "$CURRENT_DIR" 2>/dev/null || true
            return 0
        else
            log_warning "Roundcube installed but config incomplete, reconfiguring..."
        fi
    fi

    # Download
    log_info "Downloading Roundcube..."
    local RC_VERSION="1.5.0"
    local RC_FILE="roundcubemail-${RC_VERSION}-complete.tar.gz"
    local RC_URL="https://github.com/roundcube/roundcubemail/releases/download/${RC_VERSION}/${RC_FILE}"

    [ -f "$RC_FILE" ] && rm -f "$RC_FILE"

    local download_success=false
    for i in {1..3}; do
        if wget -q --timeout=30 --tries=3 "$RC_URL" -O "$RC_FILE" 2>/dev/null; then
            if [ -s "$RC_FILE" ]; then
                download_success=true
                break
            fi
        fi
        log_warning "Download attempt $i failed, retrying..."
        sleep 5
    done

    if [ "$download_success" != "true" ]; then
        log_error "Failed to download Roundcube"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi

    # Extract
    log_info "Extracting Roundcube..."
    if ! tar -xzf "$RC_FILE" 2>/dev/null; then
        log_error "Failed to extract Roundcube"
        rm -f "$RC_FILE"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi

    # Find the extracted directory
    local extracted_dir=""
    for dir in roundcubemail-*/; do
        if [ -d "$dir" ]; then
            extracted_dir="${dir%/}"
            break
        fi
    done

    if [ -z "$extracted_dir" ]; then
        log_error "Could not find extracted Roundcube directory"
        rm -f "$RC_FILE"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi

    # Move to final location
    [ -d "roundcube" ] && rm -rf roundcube

    mv "$extracted_dir" roundcube || {
        log_error "Failed to move Roundcube to final location"
        rm -f "$RC_FILE"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    }

    rm -f "$RC_FILE"

    cd roundcube || {
        log_error "Failed to change to roundcube directory"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    }

    if [ ! -d "config" ]; then
        log_error "Config directory not found in Roundcube installation"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi

    # Create config file from sample
    if [ -f "config/config.inc.php.sample" ]; then
        cp config/config.inc.php.sample config/config.inc.php
        log_info "Config file created from sample"
    else
        log_warning "Config sample not found, creating default config..."
        cat > config/config.inc.php <<'EOF'
<?php
$config = array();
$config['db_dsnw'] = '';
$config['default_host'] = 'localhost';
$config['smtp_server'] = 'localhost';
$config['smtp_port'] = 25;
$config['support_url'] = '';
$config['mail_domain'] = '';
$config['product_name'] = 'Roundcube Webmail';
$config['des_key'] = '';
$config['plugins'] = array();
$config['skin'] = 'elastic';
?>
EOF
    fi

    # Configure database connection
    log_info "Configuring Roundcube database..."
    sed -i "s|\$config\['db_dsnw'\] = .*|\$config\['db_dsnw'\] = 'mysql://$ROUNDCUBE_DB_USER:$ROUNDCUBE_DB_PASSWORD@localhost/$ROUNDCUBE_DB_NAME';|" config/config.inc.php
    sed -i "s|\$config\['default_host'\] = .*|\$config\['default_host'\] = 'localhost';|" config/config.inc.php
    sed -i "s|\$config\['smtp_server'\] = .*|\$config\['smtp_server'\] = 'localhost';|" config/config.inc.php
    sed -i "s|\$config\['smtp_port'\] = .*|\$config\['smtp_port'\] = 25;|" config/config.inc.php
    sed -i "s|\$config\['support_url'\] = .*|\$config\['support_url'\] = 'mailto:$ROUNDCUBE_ADMIN_EMAIL';|" config/config.inc.php

    # Add mail_domain
    if ! grep -q "mail_domain" config/config.inc.php; then
        sed -i "/\$config\['smtp_server'\]/a \$config['mail_domain'] = '$EMAIL_DOMAIN';" config/config.inc.php
    else
        sed -i "s|\$config\['mail_domain'\] = .*|\$config\['mail_domain'\] = '$EMAIL_DOMAIN';|" config/config.inc.php
    fi

    # Generate random des_key if not set
    if grep -q "\$config\['des_key'\] = ''" config/config.inc.php; then
        local DES_KEY=$(openssl rand -base64 24)
        sed -i "s|\$config\['des_key'\] = '';|\$config\['des_key'\] = '$DES_KEY';|" config/config.inc.php
    fi

    # Initialize database
    log_info "Initializing Roundcube database schema..."
    if [ -f "bin/initdb.sh" ]; then
        chmod +x bin/initdb.sh
        if ! ./bin/initdb.sh --dir=./SQL --create 2>/dev/null; then
            log_warning "Database initialization had issues, but continuing..."
        fi
    else
        log_warning "initdb.sh not found, skipping database initialization"
    fi

    # Set permissions
    log_info "Setting Roundcube permissions..."
    chown -R www-data:www-data . 2>/dev/null || true
    find . -type d -exec chmod 755 {} \; 2>/dev/null || true
    find . -type f -exec chmod 644 {} \; 2>/dev/null || true
    chmod 775 temp logs 2>/dev/null || true

    # Add admin user
    log_info "Adding admin user..."
    add_roundcube_user "admin" "$ROUNDCUBE_ADMIN_PASS" 1000

    cd "$CURRENT_DIR" 2>/dev/null || true

    # Verify installation
    if [ -f "/var/www/html/roundcube/config/config.inc.php" ]; then
        log_info "Roundcube installation completed successfully"
        return 0
    else
        log_error "Roundcube installation verification failed"
        return 1
    fi
}

verify_roundcube_installation() {
    local EMAIL_DOMAIN=$1

    log_info "Verifying Roundcube installation..."

    if [ ! -d "/var/www/html/roundcube" ]; then
        log_error "Roundcube directory not found"
        return 1
    fi

    if [ ! -f "/var/www/html/roundcube/config/config.inc.php" ]; then
        log_error "Roundcube config file not found"
        return 1
    fi

    local ROUNDCUBE_DB_PASSWORD=$(retrieve_file_data /usr/local/roundcube_db_pwd.txt)
    local ROUNDCUBE_DB_USER="roundcube"
    local ROUNDCUBE_DB_NAME="roundcubemail"

    if mysql -u "$ROUNDCUBE_DB_USER" -p"$ROUNDCUBE_DB_PASSWORD" -e "USE $ROUNDCUBE_DB_NAME;" 2>/dev/null; then
        log_info "Roundcube database connection successful"
    else
        log_warning "Roundcube database connection failed, reinitializing..."
        local CURRENT_DIR=$(pwd)
        cd /var/www/html/roundcube
        ./bin/initdb.sh --dir=./SQL --create 2>/dev/null || true
        cd "$CURRENT_DIR" 2>/dev/null || true
    fi

    local admin_exists=$(mysql -u "$ROUNDCUBE_DB_USER" -p"$ROUNDCUBE_DB_PASSWORD" -e "SELECT username FROM $ROUNDCUBE_DB_NAME.users WHERE username='admin';" 2>/dev/null | grep -c "admin")

    if [ "$admin_exists" -eq 0 ]; then
        log_warning "Admin user not found, creating..."
        add_roundcube_user "admin" "$(openssl rand -base64 12)" 1000
    fi

    return 0
}

