    [ -d "/var/www/html/mailx" ] && echo "  ✓ Mailx installed" || echo "  ✗ Mailx not installed"
    [ -f "/etc/letsencrypt/live/$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null)/fullchain.pem" ] 2>/dev/null && echo "  ✓ SSL Certificate installed" || echo "  ✗ SSL Certificate not installed"

