# ============================================================================

# Extract the full DKIM TXT record value from opendkim-genkey output file.
# The .txt file contains multi-line quoted strings that must be joined.
extract_dkim_record() {
    local txt_file=$1

    if [ ! -f "$txt_file" ]; then
        echo ""
        return 1
    fi

    # Method 1: Extract all quoted strings, strip quotes, join into one line
    local result
    result=$(grep -o '"[^"]*"' "$txt_file" 2>/dev/null | sed 's/"//g' | tr -d '\n\t' | sed 's/  */ /g; s/^ //; s/ $//')

    # Method 2: Fallback using awk if grep -o didn't work
    if [ -z "$result" ]; then
        result=$(awk -F'"' '{for(i=2;i<=NF;i+=2) printf "%s",$i}' "$txt_file" 2>/dev/null | sed 's/  */ /g; s/^ //; s/ $//')
    fi

    echo "$result"
}

# Generate DKIM key pair for a domain
generate_dkim_key() {
    local DOMAIN=$1
    local SELECTOR="default"
    local DKIM_BASE="/etc/opendkim"
    local KEY_DIR="$DKIM_BASE/keys/$DOMAIN"
    local KEY_FILE="$KEY_DIR/$SELECTOR.private"
    local TXT_FILE="$KEY_DIR/$SELECTOR.txt"

    # Install OpenDKIM if not present
    if ! command -v opendkim-genkey &> /dev/null; then
        log_info "Installing OpenDKIM packages..."
        apt_install opendkim opendkim-tools
    fi

    # Create opendkim user if not exists
    if ! id opendkim &>/dev/null; then
        groupadd -r opendkim 2>/dev/null || true
        useradd -r -g opendkim -s /usr/sbin/nologin opendkim 2>/dev/null || true
    fi

    # Check if key already exists
    if [ -f "$KEY_FILE" ]; then
        log_info "DKIM key already exists for domain $DOMAIN"

        # Extract DKIM record for later use
        if [ -f "$TXT_FILE" ]; then
            local DKIM_RECORD
            DKIM_RECORD=$(extract_dkim_record "$TXT_FILE")
            if [ -n "$DKIM_RECORD" ]; then
                echo "$DKIM_RECORD" > /tmp/dkim_txt_record.txt
                echo "$DKIM_RECORD" > /usr/local/mailx_dkim_record.txt
                log_info "DKIM TXT record extracted: $SELECTOR._domainkey.$DOMAIN"
            fi
        fi

        # Ensure correct ownership
        chown opendkim:opendkim "$KEY_FILE" 2>/dev/null || true
        chmod 600 "$KEY_FILE" 2>/dev/null || true
        return 0
    fi

    log_info "Generating DKIM key for domain $DOMAIN..."

    # Create directory structure
    mkdir -p "$KEY_DIR"
    chown -R opendkim:opendkim "$DKIM_BASE" 2>/dev/null || true
    chmod 750 "$DKIM_BASE"
    chmod 750 "$DKIM_BASE/keys"
    chmod 750 "$KEY_DIR"

    # Generate the key
    local CURRENT_DIR=$(pwd)
    cd "$KEY_DIR" || {
        log_error "Failed to change to key directory: $KEY_DIR"
        return 1
    }

    if ! opendkim-genkey -s "$SELECTOR" -d "$DOMAIN" -b 2048; then
        log_error "Failed to generate DKIM key"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi

    # Set proper permissions
    chmod 600 "$SELECTOR.private"
    chmod 644 "$SELECTOR.txt"
    chown opendkim:opendkim "$SELECTOR.private" "$SELECTOR.txt"

    # Extract full DKIM record (handles multi-line key correctly)
    local DKIM_RECORD
    DKIM_RECORD=$(extract_dkim_record "$SELECTOR.txt")

    if [ -n "$DKIM_RECORD" ]; then
        echo "$DKIM_RECORD" > /tmp/dkim_txt_record.txt
        echo "$DKIM_RECORD" > /usr/local/mailx_dkim_record.txt
        log_info "DKIM key generated successfully"
        log_info "DKIM TXT record: $SELECTOR._domainkey.$DOMAIN = \"$DKIM_RECORD\""
    else
        log_error "Failed to extract DKIM TXT record from generated file"
        cd "$CURRENT_DIR" 2>/dev/null || true
        return 1
    fi

    cd "$CURRENT_DIR" 2>/dev/null || true
    return 0
}

# Configure OpenDKIM daemon and integrate with Postfix
configure_opendkim() {
    local DOMAIN=$1
    local SELECTOR="default"
    local OPENDKIM_CONF="/etc/opendkim.conf"
    local OPENDKIM_DIR="/etc/opendkim"
    local SOCKET_DIR="/var/spool/postfix/opendkim"

    log_info "Configuring OpenDKIM for domain $DOMAIN..."

    # Stop any running instances
    systemctl stop opendkim 2>/dev/null || true
    pkill -f opendkim 2>/dev/null || true
    sleep 1

    # Create socket and runtime directories with correct permissions
    mkdir -p "$SOCKET_DIR"
    mkdir -p /var/run/opendkim
    chown opendkim:postfix "$SOCKET_DIR"
    chmod 750 "$SOCKET_DIR"
    chown opendkim:opendkim /var/run/opendkim
    chmod 755 /var/run/opendkim

    # Remove stale socket
    rm -f "$SOCKET_DIR/opendkim.sock" 2>/dev/null || true

    # Create necessary config directories
    mkdir -p "$OPENDKIM_DIR/keys/$DOMAIN"

    # Fix permissions
    chown -R opendkim:opendkim "$OPENDKIM_DIR" 2>/dev/null || true
    chmod 750 "$OPENDKIM_DIR"
    chmod 750 "$OPENDKIM_DIR/keys"
    chmod 750 "$OPENDKIM_DIR/keys/$DOMAIN"

    # Ensure key file has correct permissions
    if [ -f "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private" ]; then
        chmod 600 "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private"
        chown opendkim:opendkim "$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private"
    else
        log_error "DKIM private key not found: $OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private"
        return 1
    fi

    # Create main configuration
    cat > "$OPENDKIM_CONF" <<EOF
# Logging
Syslog                  yes
SyslogSuccess           yes
LogWhy                  yes

# Basic settings
Canonicalization        relaxed/simple
Mode                    sv
SubDomains              no
OversignHeaders         From
SignatureAlgorithm      rsa-sha256
UMask                   002

# User and group
UserID                  opendkim:opendkim

# Socket
Socket                  local:$SOCKET_DIR/opendkim.sock

# Domain configuration
Domain                  $DOMAIN
Selector                $SELECTOR
KeyFile                 $OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private

# Performance and reliability
AutoRestart             yes
AutoRestartRate         10/1M
DNSTimeout              5
EOF

    # Create KeyTable
    cat > "$OPENDKIM_DIR/KeyTable" <<EOF
$SELECTOR._domainkey.$DOMAIN $DOMAIN:$SELECTOR:$OPENDKIM_DIR/keys/$DOMAIN/$SELECTOR.private
EOF

    # Create SigningTable
    cat > "$OPENDKIM_DIR/SigningTable" <<EOF
*@$DOMAIN $SELECTOR._domainkey.$DOMAIN
EOF

    # Create TrustedHosts
    cat > "$OPENDKIM_DIR/TrustedHosts" <<EOF
127.0.0.1
::1
localhost
$DOMAIN
mail.$DOMAIN
EOF

    # Set config file permissions
    chmod 644 "$OPENDKIM_CONF"
    chmod 644 "$OPENDKIM_DIR/KeyTable"
    chmod 644 "$OPENDKIM_DIR/SigningTable"
    chmod 644 "$OPENDKIM_DIR/TrustedHosts"

    # Create systemd service file (replace distro default which may be broken)
    cat > /etc/systemd/system/opendkim.service <<'EOF'
[Unit]
Description=OpenDKIM DomainKeys Identified Mail Milter
After=network.target

[Service]
Type=simple
User=opendkim
Group=opendkim
ExecStart=/usr/sbin/opendkim -x /etc/opendkim.conf -f
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
EOF

    # Reload systemd and start
    systemctl daemon-reload

    log_info "Starting OpenDKIM service..."
    systemctl start opendkim

    # Wait for service to stabilize
    sleep 3

    if systemctl is-active --quiet opendkim; then
        log_info "OpenDKIM started successfully"

        # Verify socket creation
        if [ -S "$SOCKET_DIR/opendkim.sock" ]; then
            log_info "OpenDKIM socket created: $SOCKET_DIR/opendkim.sock"
            chmod 660 "$SOCKET_DIR/opendkim.sock"
            chown opendkim:postfix "$SOCKET_DIR/opendkim.sock"
        else
            log_warning "OpenDKIM socket not found, but service is running"
        fi

        # Enable service to start on boot
        systemctl enable opendkim 2>/dev/null || true

        # Configure Postfix to use DKIM milter
        log_info "Configuring Postfix for DKIM signing..."
        postconf -e "milter_default_action = accept"
        postconf -e "milter_protocol = 2"
        postconf -e "smtpd_milters = unix:opendkim/opendkim.sock"
        postconf -e "non_smtpd_milters = unix:opendkim/opendkim.sock"

        # Restart Postfix to apply changes
        systemctl restart postfix

        log_info "Postfix configured for DKIM signing"
        return 0
    else
        log_error "OpenDKIM failed to start"
        journalctl -u opendkim -n 20 --no-pager 2>/dev/null || true
        return 1
    fi
}

# Verify DKIM is working end-to-end
verify_dkim() {
    local DOMAIN=$1
    local SELECTOR="default"

    log_info "Verifying DKIM configuration..."

    # Check service
    if ! systemctl is-active --quiet opendkim; then
        log_warning "OpenDKIM is not running"
        return 1
    fi
    log_info "OpenDKIM service is running"

    # Check socket
    if [ -S "/var/spool/postfix/opendkim/opendkim.sock" ]; then
        local SOCKET_PERMS
        SOCKET_PERMS=$(stat -c "%a %U:%G" /var/spool/postfix/opendkim/opendkim.sock 2>/dev/null || echo "unknown")
        log_info "Socket permissions: $SOCKET_PERMS"
    else
        log_warning "OpenDKIM socket not found"
        return 1
    fi

    # Verify key (may fail if DNS not configured yet — that's expected)
    log_info "Testing DKIM key (may fail if DNS not propagated)..."
    if opendkim-testkey -d "$DOMAIN" -s "$SELECTOR" 2>&1 | grep -q "key OK"; then
        log_info "DKIM key verification successful"
    else
        log_warning "DKIM key test failed (DNS may not be configured yet)"
        log_info "After adding the DNS record, verify with: opendkim-testkey -d $DOMAIN -s $SELECTOR -vvv"
    fi

    # Show the DKIM record that needs to be added
    if [ -f "/tmp/dkim_txt_record.txt" ]; then
        log_info "Required DNS TXT record:"
        log_info "  Host: $SELECTOR._domainkey.$DOMAIN"
        log_info "  Value: \"$(cat /tmp/dkim_txt_record.txt)\""
    fi

    return 0
}

# ============================================================================
# SSL Certificate Functions
# ============================================================================

configure_ssl_services() {
    local domain=$1
    local cert_path="/etc/letsencrypt/live/$domain"

    if [ ! -d "$cert_path" ]; then
        log_warning "SSL certificate not found for $domain, skipping service configuration"
        return 1
    fi

    # Apache configuration
    if [ -f "/etc/apache2/sites-available/adminportal.conf" ]; then
        sed -i "s|SSLCertificateFile.*|SSLCertificateFile $cert_path/fullchain.pem|" /etc/apache2/sites-available/adminportal.conf 2>/dev/null || true
        sed -i "s|SSLCertificateKeyFile.*|SSLCertificateKeyFile $cert_path/privkey.pem|" /etc/apache2/sites-available/adminportal.conf 2>/dev/null || true
    fi

    # Postfix configuration
    postconf -e "smtpd_tls_cert_file=$cert_path/fullchain.pem" 2>/dev/null || true
    postconf -e "smtpd_tls_key_file=$cert_path/privkey.pem" 2>/dev/null || true

    # Dovecot configuration
    if [ -f "/etc/dovecot/conf.d/10-ssl.conf" ]; then
        sed -i "s|ssl_cert =.*|ssl_cert = <$cert_path/fullchain.pem|" /etc/dovecot/conf.d/10-ssl.conf 2>/dev/null || true
        sed -i "s|ssl_key =.*|ssl_key = <$cert_path/privkey.pem|" /etc/dovecot/conf.d/10-ssl.conf 2>/dev/null || true
    fi

    log_info "SSL services configured for domain $domain"
}

setup_ssl_renewal() {
    if [ -f "/usr/local/bin/ssl_renewal.sh" ]; then
        log_info "SSL renewal already configured, skipping..."
        return 0
    fi

    cat << 'EOF' > /usr/local/bin/ssl_renewal.sh
#!/bin/bash
certbot renew --quiet --post-hook "systemctl reload postfix dovecot apache2"
EOF

    chmod +x /usr/local/bin/ssl_renewal.sh
    (crontab -l 2>/dev/null | grep -v "ssl_renewal.sh"; echo "0 3 * * * /usr/local/bin/ssl_renewal.sh") | crontab - 2>/dev/null || true

    log_info "Automatic SSL renewal configured."
}

manage_ssl_certificates() {
    local action=$1
    local domain=${2:-$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null || echo "")}
    local webroot="/var/www/html"

    if [ -z "$domain" ]; then
        log_error "No domain specified for SSL certificate"
        return 1
    fi

    case "$action" in
        install)
            if [ -d "/etc/letsencrypt/live/$domain" ]; then
                log_info "SSL certificate already installed for $domain"
                configure_ssl_services "$domain"
                return 0
            fi

            if ! command -v certbot &> /dev/null; then
                log_info "Installing certbot..."
                apt_install certbot python3-certbot-apache
            fi

            mkdir -p "$webroot/.well-known/acme-challenge"
            chown -R www-data:www-data "$webroot"

            log_info "Attempting to install Let's Encrypt SSL certificate for $domain..."

            if retry_command "certbot certonly --webroot -w $webroot -d $domain -d mail.$domain --non-interactive --agree-tos --email admin@$domain --keep-until-expiring"; then
                configure_ssl_services "$domain"
                setup_ssl_renewal
                log_info "SSL certificate installed successfully"
                return 0
            else
                log_error "Failed to obtain SSL certificate"
                return 1
            fi
            ;;

        renew)
            log_info "Renewing SSL certificates..."
            certbot renew --quiet --post-hook "systemctl reload postfix dovecot apache2" || true
            ;;

        change)
            local new_domain=$2
            if [[ -z "$new_domain" ]]; then
                log_error "New domain not specified"
                return 1
            fi

            log_info "Changing SSL certificate from $domain to $new_domain..."
            certbot certonly --webroot -w "$webroot" -d "$new_domain" -d "mail.$new_domain" \
                --non-interactive --agree-tos --email admin@$new_domain --keep-until-expiring --force-renewal || true

            configure_ssl_services "$new_domain"
            ;;

        *)
            log_error "Usage: manage_ssl_certificates [install|renew|change newdomain.com]"
            return 1
            ;;
    esac
}

