send_test_message() {
    if ! dpkg -l | grep -q mailutils; then
        apt-get update && apt-get install -y mailutils
    fi

    local email_to=$1
    local email_subject=$2
    local email_body=$3
    local email_domain=$(retrieve_file_data /usr/local/roundcube_mail_domain.txt 2>/dev/null || echo "localhost")

    echo -e "$email_body" | mail -s "$email_subject" -a "From: admin@$email_domain" "$email_to" 2>/dev/null || true
    log_info "Test mail sent to $email_to"
}

